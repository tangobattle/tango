component LIcon inherits Text {
    font-family: "lucide";
    color: Theme.text;
    vertical-alignment: center;
    horizontal-alignment: center;
}

// The signature asymmetric corner: top-left/bottom-right = r,
// top-right/bottom-left = min(r * 0.25, 3px).
component TechPlate inherits Rectangle {
    in property <length> r: 10px;
    border-top-left-radius: r;
    border-bottom-right-radius: r;
    border-top-right-radius: min(r * 0.25, 3px);
    border-bottom-left-radius: min(r * 0.25, 3px);
}

// Minimal tinted plate with hairline accent border — tab regions,
// list containers. Pair with 12px padding inside.
component Pane inherits Rectangle {
    background: Theme.plate;
    border-radius: 4px;
    border-width: 1px;
    border-color: Theme.hairline;
}

// Framed PET card — empty states, modals.
component Panel inherits TechPlate {
    r: 14px;
    background: Theme.panel-bg;
    border-width: 1.5px;
    border-color: #4caf5080;
    drop-shadow-blur: 24px;
    drop-shadow-color: Theme.light ? #00000040 : #000000aa;
    drop-shadow-offset-y: 6px;
}

component PillTab inherits TechPlate {
    in property <string> glyph;
    in property <string> label;
    in property <bool> active;
    callback clicked();

    r: 10px;
    background: root.active
        ? @linear-gradient(180deg, #58bd5c 0%, #3e9a42 100%)
        : (ta.has-hover ? Theme.hover : transparent);
    drop-shadow-blur: root.active ? 12px : 0px;
    drop-shadow-color: root.active ? #4caf5066 : transparent;

    ta := TouchArea {
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-top: 8px;
        padding-bottom: 8px;
        padding-left: 18px;
        padding-right: 18px;
        spacing: root.label == "" ? 0 : 8px;
        LIcon {
            text: root.glyph;
            font-size: 15px;
            color: root.active ? white : Theme.text-muted;
        }
        if root.label != "" : Text {
            text: root.label;
            font-size: 15px;
            color: root.active ? white : Theme.text-muted;
            vertical-alignment: center;
        }
    }
}

component PrimaryButton inherits TechPlate {
    in property <string> glyph;
    in property <string> label;
    in property <bool> enabled: true;
    in property <length> pad-v: 6px;
    in property <length> pad-h: 14px;
    in property <length> text-size: 13px;
    callback clicked();

    r: 10px;
    background: !root.enabled
        ? Theme.plate-input
        : (ta.has-hover
            ? @linear-gradient(180deg, #63cc67 0%, #46a84a 100%)
            : @linear-gradient(180deg, #58bd5c 0%, #3e9a42 100%));
    drop-shadow-blur: root.enabled ? 10px : 0px;
    drop-shadow-color: root.enabled ? #4caf5059 : transparent;

    ta := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-top: root.pad-v;
        padding-bottom: root.pad-v;
        padding-left: root.pad-h;
        padding-right: root.pad-h;
        spacing: root.glyph == "" || root.label == "" ? 0 : 8px;
        // Center so a fixed-width instance (the lobby's Ready button,
        // pinned so its three labels never shift the bar) doesn't
        // stretch its content left. No-op when sized by content.
        alignment: center;
        if root.glyph != "" : LIcon {
            text: root.glyph;
            font-size: root.text-size;
            color: root.enabled ? white : Theme.disabled-text;
        }
        if root.label != "" : Text {
            text: root.label;
            font-size: root.text-size;
            color: root.enabled ? white : Theme.disabled-text;
            vertical-alignment: center;
        }
    }
}

// Icon-only danger action (the lobby's Leave) — quiet plate at rest,
// red tint + border on hover, like tango's widgets::danger_button.
component DangerIconButton inherits TechPlate {
    in property <string> glyph;
    in property <bool> enabled: true;
    callback clicked();

    r: 10px;
    background: root.enabled && ta.has-hover ? #ff525226 : Theme.btn-plate;
    border-width: 1px;
    border-color: root.enabled && ta.has-hover ? #ff5252aa : Theme.input-border;

    ta := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-top: 10px;
        padding-bottom: 10px;
        padding-left: 12px;
        padding-right: 12px;
        LIcon {
            text: root.glyph;
            font-size: 15px;
            color: root.enabled ? Theme.danger : Theme.disabled-text;
        }
    }
}

// Soft 3D plate, low-emphasis toolbar button (icon-only).
component NeutralButton inherits TechPlate {
    in property <string> glyph;
    in property <bool> enabled: true;
    callback clicked();

    r: 10px;
    background: !root.enabled ? Theme.plate-input : (ta.has-hover ? Theme.hover : Theme.btn-plate);
    border-width: 1px;
    border-color: Theme.input-border;

    ta := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-top: 6px;
        padding-bottom: 6px;
        padding-left: 14px;
        padding-right: 14px;
        LIcon {
            text: root.glyph;
            font-size: 13px;
            color: root.enabled ? Theme.text : Theme.disabled-text;
        }
    }
}

// NeutralButton with a text label instead of a glyph — the save
// viewer's copy affordances (the Glyphs table has no clipboard icons).
component NeutralTextButton inherits TechPlate {
    in property <string> label;
    callback clicked();

    r: 10px;
    background: ta.has-hover ? Theme.hover : Theme.btn-plate;
    border-width: 1px;
    border-color: Theme.input-border;

    ta := TouchArea {
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-top: 5px;
        padding-bottom: 5px;
        padding-left: 12px;
        padding-right: 12px;
        Text {
            text: root.label;
            font-size: 12px;
            color: Theme.text;
            vertical-alignment: center;
        }
    }
}

// NeutralTextButton's danger twin (widgets::danger_button with a
// label): quiet plate at rest, red tint + border on hover.
component DangerTextButton inherits TechPlate {
    in property <string> label;
    callback clicked();

    r: 10px;
    background: ta.has-hover ? #ff525226 : Theme.btn-plate;
    border-width: 1px;
    border-color: ta.has-hover ? #ff5252aa : Theme.input-border;

    ta := TouchArea {
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-top: 5px;
        padding-bottom: 5px;
        padding-left: 12px;
        padding-right: 12px;
        Text {
            text: root.label;
            font-size: 12px;
            color: ta.has-hover ? #ff8a8a : Theme.text;
            vertical-alignment: center;
        }
    }
}

// One row of the save-actions ⋮ popup menu (widgets::MenuItem).
component MenuRow inherits Rectangle {
    in property <string> label;
    in property <bool> danger: false;
    callback clicked();

    height: 30px;
    background: ta.has-hover ? Theme.hover : transparent;

    ta := TouchArea {
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        Text {
            text: root.label;
            font-size: 13px;
            color: root.danger ? #ff8a8a : Theme.text;
            vertical-alignment: center;
        }
    }
}

// Chunky pick_list stand-in: plate trigger + popup list with zebra
// rows and the gold selection register.
component Picker inherits TechPlate {
    in property <[string]> model;
    in property <string> placeholder;
    in property <bool> enabled: true;
    in-out property <int> current: -1;
    callback selected(int);

    r: 10px;
    height: 34px;
    background: !root.enabled ? Theme.plate-input : (ta.has-hover ? Theme.hover : Theme.btn-plate);
    border-width: 1px;
    border-color: !root.enabled ? transparent : Theme.input-border;

    ta := TouchArea {
        enabled: root.enabled && root.model.length > 0;
        clicked => { popup.show(); }
    }

    HorizontalLayout {
        padding-left: 14px;
        padding-right: 10px;
        spacing: 6px;
        Text {
            text: root.current >= 0 && root.current < root.model.length
                ? root.model[root.current]
                : root.placeholder;
            color: !root.enabled
                ? Theme.disabled-text
                : (root.current >= 0 ? Theme.text : Theme.text-muted);
            font-size: 13px;
            vertical-alignment: center;
            overflow: elide;
            horizontal-stretch: 1;
        }
        LIcon {
            text: Glyphs.chevron-down;
            font-size: 11px;
            color: root.enabled ? Theme.text-muted : Theme.disabled-text;
        }
    }

    popup := PopupWindow {
        x: 0;
        y: root.height + 2px;
        width: max(root.width, 180px);
        height: min(root.model.length * 34px + 10px, 340px);
        close-policy: close-on-click-outside;

        Rectangle {
            background: Theme.plate-popup;
            border-width: 1px;
            border-color: Theme.hairline;
            border-radius: 4px;

            ListView {
                x: 4px;
                y: 4px;
                width: parent.width - 8px;
                height: parent.height - 8px;
                for item[i] in root.model : Rectangle {
                    height: 34px;
                    border-radius: 4px;
                    background: i == root.current
                        ? @linear-gradient(180deg, #ffd23d 0%, #e6b520 100%)
                        : (ita.has-hover
                            ? Theme.hover
                            : (Math.mod(i, 2) == 0 ? transparent : Theme.row-alt));
                    ita := TouchArea {
                        clicked => {
                            root.current = i;
                            root.selected(i);
                            popup.close();
                        }
                    }
                    Text {
                        x: 10px;
                        width: parent.width - 20px;
                        height: parent.height;
                        text: item;
                        font-size: 13px;
                        color: i == root.current ? Theme.ink : Theme.text;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }
            }
        }
    }
}

// Chunky text input: plate + accent focus ring, accepts on Enter.
// `placeholder` shows muted while the input is empty.
component ChunkyInput inherits TechPlate {
    in-out property <string> text <=> ti.text;
    in property <string> placeholder;
    in property <bool> enabled: true;
    // Streamer privacy: render the content as password dots.
    in property <bool> masked: false;
    callback accepted(string);
    callback edited(string);

    r: 10px;
    height: 34px;
    background: !root.enabled ? Theme.plate-input : Theme.btn-plate;
    border-width: 1px;
    border-color: ti.has-focus ? Theme.primary : Theme.input-border;

    if ti.text == "" : Text {
        x: 14px;
        width: parent.width - 28px;
        height: parent.height;
        text: root.placeholder;
        color: Theme.text-muted;
        font-size: 13px;
        vertical-alignment: center;
        overflow: elide;
    }

    ti := TextInput {
        x: 14px;
        width: parent.width - 28px;
        height: parent.height;
        vertical-alignment: center;
        color: root.enabled ? Theme.text : Theme.disabled-text;
        font-size: 13px;
        single-line: true;
        enabled: root.enabled;
        input-type: root.masked ? InputType.password : InputType.text;
        accepted => { root.accepted(self.text); }
        edited => { root.edited(self.text); }
    }
}

// Chunky slider: 6px rail + circular handle (widgets::chunky_slider).
component ChunkySlider inherits Rectangle {
    in-out property <float> value: 1.0; // 0..1
    in property <bool> enabled: true;
    callback changed(float);

    height: 24px;
    width: 220px;

    Rectangle {
        y: parent.height / 2 - 3px;
        height: 6px;
        width: 100%;
        border-radius: 3px;
        background: Theme.plate-input;
        border-width: 1px;
        border-color: Theme.input-border;
    }
    Rectangle {
        y: parent.height / 2 - 3px;
        height: 6px;
        width: parent.width * root.value;
        border-radius: 3px;
        background: Theme.primary;
    }
    Rectangle {
        x: parent.width * root.value - 8px;
        y: parent.height / 2 - 8px;
        width: 16px;
        height: 16px;
        border-radius: 8px;
        background: white;
        border-width: 1px;
        border-color: #00000040;
    }
    TouchArea {
        enabled: root.enabled;
        moved => {
            if (self.pressed) {
                root.value = max(0.0, min(1.0, self.mouse-x / root.width));
                root.changed(root.value);
            }
        }
        clicked => {
            root.value = max(0.0, min(1.0, self.mouse-x / root.width));
            root.changed(root.value);
        }
    }
}

// Chunky checkbox: rounded box, primary fill + check glyph when on.
component ChunkyCheckbox inherits HorizontalLayout {
    in property <string> label;
    in property <bool> enabled: true;
    in-out property <bool> checked;
    callback toggled(bool);

    spacing: 8px;
    Rectangle {
        width: 18px;
        height: 18px;
        border-radius: 5px;
        background: root.checked ? Theme.primary : Theme.btn-plate;
        border-width: 1px;
        border-color: root.checked ? Theme.primary : Theme.input-border;
        TouchArea {
            enabled: root.enabled;
            clicked => {
                root.checked = !root.checked;
                root.toggled(root.checked);
            }
        }
        if root.checked : LIcon {
            width: 100%;
            height: 100%;
            text: "\u{e06c}"; // check
            font-size: 12px;
            color: white;
        }
    }
    Text {
        text: root.label;
        font-size: 13px;
        color: Theme.text;
        vertical-alignment: center;
    }
}

// Caption-over-control form row (widgets::labeled), gap 4.
component Labeled inherits VerticalLayout {
    in property <string> label;
    spacing: 4px;
    Text {
        text: root.label;
        font-size: 11px;
        color: Theme.text-muted;
    }
    @children
}

// Centered empty-state text on a pane (widgets::pane_prompt).
component PanePrompt inherits Pane {
    in property <string> message;
    Text {
        width: 100%;
        height: 100%;
        text: root.message;
        color: Theme.text-muted;
        font-size: 13px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

// 3px accent gradient strip (widgets::hud_scanline).
component Scanline inherits Rectangle {
    height: 3px;
    background: @linear-gradient(90deg, #4caf5000 0%, #4caf50b3 30%, #4caf50b3 70%, #4caf5000 100%);
}

// One lobby matchup side card (tango's tabs/play/lobby.rs side_card):
// ready dot beside a caption / nickname / subline column. The dot is a
// 14px "ready light" — green with a soft glow when that side has
// committed, muted gray otherwise — padded down so it rides the
// nickname row. The nickname tints primary when ready.
component LobbySideCard inherits HorizontalLayout {
    in property <string> role-label;
    in property <string> nickname;
    in property <string> subline;
    in property <bool> ready;

    spacing: 10px;
    Rectangle {
        width: 14px;
        Rectangle {
            y: 20px;
            width: 14px;
            height: 14px;
            border-radius: 7px;
            background: root.ready ? Theme.primary : Theme.text-muted;
            drop-shadow-blur: root.ready ? 10px : 0px;
            drop-shadow-color: root.ready ? #4caf50b3 : transparent;
        }
    }
    VerticalLayout {
        spacing: 2px;
        alignment: start;
        Text {
            text: root.role-label;
            font-size: 11px;
            color: Theme.text-muted;
        }
        Text {
            text: root.nickname;
            font-size: 18px;
            color: root.ready ? Theme.primary : Theme.text;
            overflow: elide;
        }
        Text {
            text: root.subline;
            font-size: 11px;
            color: Theme.text-muted;
            overflow: elide;
        }
    }
}

// One replay-list row's display strings.
export struct ReplayRow {
    line1: string,
    line2: string,
}

// One patches-list row's display strings.
export struct PatchRow {
    title: string,
    authors: string,
    // Favorites sort first and wear a gold star.
    favorite: bool,
}

// ---- save viewer (read-only) ----
// Model shapes are baked in Rust (src/loaded.rs) from tango's
// save_view data; the layouts below are ports of
// tango/src/save_view/{folder.rs,navi/mod.rs}'s read-only views.

// One folder row: pre-resolved strings + pre-baked sprite handles.
export struct ChipRow {
    icon: image,
    element-icon: image,
    name: string,
    code: string,
    power: string,
    mb: string,
    // "N×" — only rendered in grouped mode.
    count: string,
    is-regular: bool,
    // One TAG badge per tagged copy (the pair can collapse onto one
    // grouped row).
    tag-count: int,
    // Class accent stripe (Mega/Giga/dark); has-accent gates it since
    // color has no "none".
    accent: color,
    has-accent: bool,
    // Grouped empty-slot row ("—"): muted name, no stats.
    is-empty: bool,
    // Chip flavor text, for the hover popover (follow-up).
    description: string,
    // Library rows only: whether adding this chip is currently legal
    // (folder not full, copy/class caps).
    addable: bool,
}

// The equipped-navi header card. has-name gates the emblem + name
// (roster games only — BN1–4 show just the stats row).
export struct NaviHeader {
    emblem: image,
    has-name: bool,
    name: string,
    hp: string,
    buster-attack: string,
    buster-rapid: string,
    buster-charge: string,
    has-buster: bool,
}

// Save-view section tab entry. `kind` picks the section body (0 =
// NaviCust, 1 = Folder, 2 = Patch Cards, 3 = Auto Battle Data): the
// strip only holds the sections this save's views support (tango's
// available_tabs), so the index alone can't identify a section.
export struct SaveTabItem {
    label: string,
    kind: int,
}

// One installed NaviCust part (save_view/navicust's parts panel):
// baked shape thumb, name plate tinted with the part's NCP color,
// and the ROM's description text.
export struct NcpPartRow {
    thumb: image,
    name: string,
    tint: color,
    desc: string,
}

// One display line of the Patch Cards section, flattened in Rust
// (save_view/patch_cards render_patch_cards): a card with N effect
// badges spans N lines — only the first line carries the index /
// name / MB cell. `zebra` is the card index, so all of one card's
// lines share a wash.
export struct PatchCardLine {
    first: bool,
    zebra: int,
    idx: string,
    name: string,
    mb: string,
    enabled: bool,
    ability: string,
    ability-debuff: bool,
    bug: string,
    bug-debuff: bool,
    // BN4: the bug renders as a plain purple line under the card's
    // row instead of a badge column.
    bug-plain: bool,
}

// One cell of the navi picker's roster strip.
export struct NaviCell {
    emblem: image,
    name: string,
    selected: bool,
}

// One row of the ABD editor's use-count library.
export struct AbdLibRow {
    icon: image,
    name: string,
    used: int,
    sec: int,
    has-sec: bool,
}

// One row of the Auto Battle Data section, flattened in Rust
// (save_view/abd render_auto_battle_data): six titled sections whose
// chip rows reuse the folder's ChipRow shape (code stays empty; the
// count column is always on).
export struct AbdRow {
    is-header: bool,
    title: string,
    chip: ChipRow,
    zebra: int,
}

// One Cover-tab logo, pre-positioned in Rust (save_view/cover.rs):
// display-px coordinates inside the lane box the pane centers.
export struct CoverLogo {
    img: image,
    x: float,
    y: float,
    w: float,
    h: float,
}

// REG / TAG indicator chip (save_view's badge()).
component Badge inherits Rectangle {
    in property <string> label;
    in property <color> tint;
    background: tint;
    border-radius: 3px;
    HorizontalLayout {
        padding-left: 4px;
        padding-right: 4px;
        padding-top: 1px;
        padding-bottom: 1px;
        Text {
            text: root.label;
            font-size: 10px;
            color: white;
            vertical-alignment: center;
        }
    }
}

// One "label value" stat pair (save_view/navi's stat_inline): muted
// caption with its value flush beside it.
component StatInline inherits HorizontalLayout {
    in property <string> label;
    in property <string> value;
    spacing: 5px;
    alignment: start;
    Text {
        text: root.label;
        font-size: 11px;
        color: Theme.text-muted;
        vertical-alignment: bottom;
    }
    Text {
        text: root.value;
        font-size: 15px;
        color: Theme.text;
        vertical-alignment: bottom;
    }
}

// Save-view section tab: PillTab minus the glyph — the strip is built
// from a plain [string] model so future sections (NaviCust, Patch
// Cards, ABD) slot in from Rust without touching the layout.
component SaveTab inherits TechPlate {
    in property <string> label;
    in property <bool> active;
    callback clicked();

    r: 10px;
    background: root.active
        ? @linear-gradient(180deg, #58bd5c 0%, #3e9a42 100%)
        : (ta.has-hover ? Theme.hover : transparent);

    ta := TouchArea {
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-top: 6px;
        padding-bottom: 6px;
        padding-left: 16px;
        padding-right: 16px;
        Text {
            text: root.label;
            font-size: 13px;
            color: root.active ? white : Theme.text-muted;
            vertical-alignment: center;
        }
    }
}

// ---- input settings (the drawn GBA console shell) ----
// Slint port of tango's tabs/settings.rs settings_input console: the
// clickable keys select which slot the LCD bezel edits; a key lights
// primary-flush while any of its bindings is physically held.

// One binding chip shown on the LCD: source glyph (keyboard/gamepad,
// resolved in Rust), display label, and live held state.
export struct InputChip {
    glyph: string,
    label: string,
    lit: bool,
}

// One clickable console key (tango's gba_key chrome): molded plate a
// step above the shell, primary ring when selected (the LCD is
// showing this key), primary flush while a binding is held. Both are
// color-only so live input never shifts the layout. Corner radii are
// set per instance (pills, D-pad arms, round A/B).
component GbaKey inherits Rectangle {
    in property <string> glyph;
    in property <string> label;
    in property <length> text-size: 13px;
    // Horizontal content padding — 0 for the fixed-size keys (their
    // box is the padding), set on content-sized ones (the
    // fast-forward pill).
    in property <length> pad-h: 0px;
    in property <bool> selected;
    in property <bool> lit;
    callback clicked();

    property <color> plate: Theme.light ? #fbf9f3 : #323434;
    property <color> base: ta.pressed
        ? plate.mix(#000000, 0.9)
        : (ta.has-hover ? plate.mix(#ffffff, Theme.light ? 0.8 : 0.88) : plate);
    background: root.lit ? base.mix(Theme.primary, 0.45) : base;
    border-width: root.selected ? 2px : 1px;
    border-color: root.selected
        ? Theme.primary
        : (ta.has-hover ? Theme.primary.transparentize(0.3) : Theme.input-border);
    drop-shadow-blur: 6px;
    drop-shadow-offset-y: ta.pressed ? 1px : 2px;
    drop-shadow-color: Theme.light ? #0000001f : #00000059;

    ta := TouchArea {
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        alignment: center;
        padding-left: root.pad-h;
        padding-right: root.pad-h;
        spacing: root.glyph != "" && root.label != "" ? 6px : 0;
        if root.glyph != "" : LIcon {
            text: root.glyph;
            font-size: root.text-size;
        }
        if root.label != "" : Text {
            text: root.label;
            font-size: root.text-size;
            color: Theme.text;
            vertical-alignment: center;
            horizontal-alignment: center;
        }
    }
}

// The read-only save viewer's models + interactions, shared by every
// embedder (play tab now; the replay tab's local-save view and the
// in-session setup drawers render the same body). Rust pushes models
// through the global; the strip's tail controls fire its callbacks.
export global SaveView {
    // True while a Loaded is built for the current selection; false
    // clears the whole viewer (deselect / rescan).
    in-out property <bool> save-loaded: false;
    in-out property <NaviHeader> navi-header;
    // Section tabs, pushed from Rust with tango's save-tab-* strings —
    // one entry per view the save supports (available_tabs).
    in-out property <[SaveTabItem]> save-tabs: [];
    in-out property <int> save-active-tab: 0;
    // The active section's kind (-1 = none): the bodies and the strip's
    // tail controls gate on this, not on the tab index.
    out property <int> save-kind: save-tabs.length > 0
        && save-active-tab >= 0
        && save-active-tab < save-tabs.length
        ? save-tabs[save-active-tab].kind : -1;
    in-out property <[ChipRow]> folder-chips: [];
    // BN1/2 chips carry no MB — the whole column hides.
    in-out property <bool> folder-has-mb: true;
    in-out property <bool> folder-grouped: true;
    // ---- navicust section ----
    in-out property <image> navicust-image;
    // Baked image aspect (w / h): the image box is height-driven, so
    // narrower grids render proportionally smaller.
    in-out property <float> navicust-aspect: 1.0;
    // BN3 style name, overlaid on the color bar ("" = none). The fracs
    // locate the bar's label line in the image's own coordinate space.
    in-out property <string> navicust-style-name: "";
    in-out property <float> navicust-label-x-frac: 0.0;
    in-out property <float> navicust-label-y-frac: 0.0;
    in-out property <float> navicust-label-h-frac: 0.0;
    // Installed parts, solid parts first then plus parts (slot order
    // within each group), like tango's parts panel.
    in-out property <[NcpPartRow]> navicust-parts: [];
    // ---- patch cards section ----
    // 0 = BN5/BN6 badge-column list, 1 = BN4 catalog slots.
    in-out property <int> patch-cards-kind: 0;
    in-out property <[PatchCardLine]> patch-card-lines: [];
    // ---- auto battle data section ----
    in-out property <[AbdRow]> abd-rows: [];
    // Cover section (streamer mode only).
    in-out property <[CoverLogo]> cover-logos: [];
    in-out property <float> cover-lane-w: 0.0;
    in-out property <float> cover-lane-h: 0.0;
    // Transient "Copied!" flashes on the copy buttons (set from Rust,
    // cleared by a single-shot timer there).
    in-out property <bool> save-copy-flash: false;
    in-out property <bool> save-copy-image-flash: false;
    // ---- save editing (save_edit.rs; folder editor so far) ----
    // The Edit affordance shows (play-tab source + editable save).
    in-out property <bool> editable: false;
    // One global edit session; Save/Cancel commits/discards it all.
    in-out property <bool> editing: false;
    // Folder editor panes: per-slot folder rows + the chip library.
    in-out property <[ChipRow]> edit-folder-rows: [];
    in-out property <[ChipRow]> edit-library-rows: [];
    callback edit-enter();
    callback edit-commit();
    callback edit-cancel();
    // Library row index → add that (chip, code) to the folder.
    callback edit-add(int);
    callback edit-remove(int);
    // (slot, ±1) — ordered move via the row's arrows.
    callback edit-move(int, int);
    callback edit-toggle-regular(int);
    callback edit-toggle-tag(int);
    callback edit-clear();
    callback edit-filter-edited(string);
    // Patch-card editor: library index / registered slot arguments.
    callback pc-edit-add(int);
    callback pc-edit-remove(int);
    callback pc-edit-move(int, int);
    callback pc-edit-toggle(int);
    // ABD editor: (library index, ±delta) count steppers.
    in-out property <[AbdLibRow]> edit-abd-rows: [];
    callback abd-edit-used(int, int);
    callback abd-edit-sec(int, int);
    // Navi picker (shows while editing on navi-writable saves).
    in-out property <bool> edit-navi-editable: false;
    in-out property <[NaviCell]> edit-navi-cells: [];
    callback edit-set-navi(int);
    callback folder-grouped-toggled(bool);
    // Copy the active section as TSV text / the NaviCust grid as an
    // image (tango's CopyTab/CopyTabImage).
    callback save-copy();
    callback save-copy-image();
}

// The save viewer's whole body: navi header card, section tab strip
// (with the folder-group toggle + copy buttons in its tail), and the
// active section's pane — everything below an embedder's own chrome.
component SaveViewBody inherits VerticalLayout {
    // ---- save viewer (read-only) ----
    // Navi header card over a tab strip + the
    // active section's pane. Only the Folder
    // section is ported so far; the strip is
    // model-driven so the rest slot in later.
    if SaveView.save-loaded : VerticalLayout {
        spacing: 8px;
        vertical-stretch: 1;

        // navi header card (save_view/navi/mod.rs
        // navi_card_content): emblem beside
        // name-over-stats for the roster games
        // (BN5/BN6/EXE4.5); BN1–4 just the HP.
        Pane {
            HorizontalLayout {
                padding: 12px;
                spacing: 10px;
                alignment: start;
                if SaveView.navi-header.has-name : VerticalLayout {
                    alignment: center;
                    Image {
                        // 3× the 15px emblem crop so the
                        // nearest-neighbor upscale lands
                        // on even pixels.
                        width: 45px;
                        height: 45px;
                        source: SaveView.navi-header.emblem;
                        image-fit: contain;
                        image-rendering: pixelated;
                    }
                }
                VerticalLayout {
                    spacing: 4px;
                    alignment: center;
                    if SaveView.navi-header.has-name : Text {
                        text: SaveView.navi-header.name;
                        font-size: 18px;
                        color: Theme.text;
                    }
                    HorizontalLayout {
                        spacing: 16px;
                        alignment: start;
                        if SaveView.navi-header.hp != "" : StatInline {
                            label: I18n.navi-base-hp;
                            value: SaveView.navi-header.hp;
                        }
                        if SaveView.navi-header.has-buster : HorizontalLayout {
                            spacing: 12px;
                            alignment: start;
                            StatInline {
                                label: I18n.navi-buster-attack;
                                value: SaveView.navi-header.buster-attack;
                            }
                            StatInline {
                                label: I18n.navi-buster-rapid;
                                value: SaveView.navi-header.buster-rapid;
                            }
                            StatInline {
                                label: I18n.navi-buster-charge;
                                value: SaveView.navi-header.buster-charge;
                            }
                        }
                    }
                }
            }
        }

        // Navi picker (render_navi_edit, condensed): the roster as an
        // emblem strip; clicking a cell stages SetNavi — which can add
        // or remove whole sections, so Rust re-pushes everything.
        if SaveView.editing && SaveView.edit-navi-editable : Pane {
            Flickable {
                height: 64px;
                viewport-width: self.width;
                HorizontalLayout {
                    padding: 8px;
                    spacing: 8px;
                    alignment: start;
                    for cell[i] in SaveView.edit-navi-cells : Rectangle {
                        width: 48px;
                        height: 48px;
                        border-radius: 8px;
                        background: cell.selected
                            ? #29a12133
                            : (nvta.has-hover ? Theme.hover : Theme.btn-plate);
                        border-width: cell.selected ? 2px : 1px;
                        border-color: cell.selected ? #29a121 : Theme.input-border;
                        nvta := TouchArea {
                            clicked => { SaveView.edit-set-navi(i); }
                        }
                        Image {
                            width: 30px;
                            height: 30px;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            source: cell.emblem;
                            image-fit: contain;
                            image-rendering: pixelated;
                        }
                    }
                }
            }
        }

        // tab strip + the active section's tail
        // controls (folder's grouped toggle, the
        // copy buttons)
        HorizontalLayout {
            spacing: 4px;
            for tab[i] in SaveView.save-tabs : SaveTab {
                label: tab.label;
                active: SaveView.save-active-tab == i;
                clicked => { SaveView.save-active-tab = i; }
            }
            Rectangle { horizontal-stretch: 1; }
                if SaveView.save-kind == 1 && !SaveView.editing : VerticalLayout {
                alignment: center;
                ChunkyCheckbox {
                    label: I18n.folder-group;
                    checked <=> SaveView.folder-grouped;
                    toggled(g) => { SaveView.folder-grouped-toggled(g); }
                }
            }
            if SaveView.editable && SaveView.save-kind >= 1 && SaveView.save-kind <= 3 && !SaveView.editing : VerticalLayout {
                alignment: center;
                NeutralTextButton {
                    label: I18n.save-edit;
                    clicked => { SaveView.edit-enter(); }
                }
            }
            if SaveView.editing : VerticalLayout {
                alignment: center;
                HorizontalLayout {
                    spacing: 6px;
                    DangerTextButton {
                        label: I18n.save-edit-clear;
                        clicked => { SaveView.edit-clear(); }
                    }
                    NeutralTextButton {
                        label: I18n.save-edit-cancel;
                        clicked => { SaveView.edit-cancel(); }
                    }
                    PrimaryButton {
                        label: I18n.save-edit-save;
                        pad-v: 5px;
                        pad-h: 12px;
                        clicked => { SaveView.edit-commit(); }
                    }
                }
            }
            if SaveView.save-kind == 0 : VerticalLayout {
                alignment: center;
                NeutralTextButton {
                    label: SaveView.save-copy-image-flash ? I18n.copied : I18n.save-copy-image;
                    clicked => { SaveView.save-copy-image(); }
                }
            }
            if SaveView.save-kind >= 0 : VerticalLayout {
                alignment: center;
                NeutralTextButton {
                    label: SaveView.save-copy-flash ? I18n.copied : I18n.save-copy;
                    clicked => { SaveView.save-copy(); }
                }
            }
        }

        // Cover (save_view/cover.rs, streamer mode
        // only): the game's logo(s), positioned in
        // Rust — single = centered banner, twin
        // versions = staggered pair.
        if SaveView.save-kind == 4 : Pane {
            vertical-stretch: 1;
            Rectangle {
                width: SaveView.cover-lane-w * 1px;
                height: SaveView.cover-lane-h * 1px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                for logo in SaveView.cover-logos : Image {
                    x: logo.x * 1px;
                    y: logo.y * 1px;
                    width: logo.w * 1px;
                    height: logo.h * 1px;
                    source: logo.img;
                    image-fit: contain;
                }
            }
        }

        // NaviCust (save_view/navicust): the baked
        // grid image beside the installed-parts
        // list. The image box is height-driven so
        // the grid always fits the pane; BN3's
        // style name overlays the color bar.
        if SaveView.save-kind == 0 : Pane {
            vertical-stretch: 1;
            // Manually placed (no layout): the grid box is
            // height-driven (width = height × aspect), which
            // inside a layout would cycle the layout solver.
            ncgrid := Rectangle {
                x: 12px;
                y: 12px;
                height: parent.height - 24px;
                width: self.height * SaveView.navicust-aspect;
                clip: true;
                border-radius: 6px;
                Image {
                    width: 100%;
                    height: 100%;
                    source: SaveView.navicust-image;
                    image-fit: contain;
                }
                if SaveView.navicust-style-name != "" : Text {
                    x: parent.width * SaveView.navicust-label-x-frac;
                    y: parent.height * SaveView.navicust-label-y-frac;
                    height: parent.height * SaveView.navicust-label-h-frac;
                    text: SaveView.navicust-style-name;
                    font-size: self.height * 0.5;
                    color: white;
                    vertical-alignment: center;
                }
            }
            ListView {
                x: ncgrid.x + ncgrid.width + 16px;
                y: 4px;
                width: parent.width - self.x - 12px;
                height: parent.height - 8px;
                for part in SaveView.navicust-parts : HorizontalLayout {
                        padding-top: 5px;
                        padding-bottom: 5px;
                        spacing: 10px;
                        Rectangle {
                            width: 40px;
                            Image {
                                width: min(parent.width, self.source.width * 1px);
                                height: min(40px, self.source.height * 1px);
                                source: part.thumb;
                                image-fit: contain;
                                image-rendering: pixelated;
                            }
                        }
                        VerticalLayout {
                            horizontal-stretch: 1;
                            spacing: 3px;
                            alignment: center;
                            HorizontalLayout {
                                alignment: start;
                                Rectangle {
                                    background: part.tint;
                                    border-radius: 6px;
                                    HorizontalLayout {
                                        padding-left: 8px;
                                        padding-right: 8px;
                                        padding-top: 3px;
                                        padding-bottom: 3px;
                                        Text {
                                            text: part.name;
                                            font-size: 13px;
                                            color: black;
                                        }
                                    }
                                }
                            }
                            if part.desc != "" : Text {
                                text: part.desc;
                                font-size: 11px;
                                color: Theme.text-muted;
                                wrap: word-wrap;
                            }
                        }
                    }
                }
        }

        // Patch Cards (save_view/patch_cards):
        // flattened lines — BN5/BN6 rows carry
        // ability / bug badge columns; BN4 rows are
        // the six catalog slots with purple bug
        // lines beneath.
        if SaveView.save-kind == 2 && !SaveView.editing : Pane {
            vertical-stretch: 1;
            ListView {
                x: 1px;
                y: 4px;
                width: parent.width - 2px;
                height: parent.height - 8px;
                for line in SaveView.patch-card-lines : Rectangle {
                    height: 26px;
                    background: Math.mod(line.zebra, 2) == 0 ? transparent : Theme.row-alt;
                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        spacing: 8px;
                        Text {
                            width: SaveView.patch-cards-kind == 0 ? 24px : 34px;
                            text: line.idx;
                            font-size: 11px;
                            color: Theme.text-muted;
                            vertical-alignment: center;
                            horizontal-alignment: SaveView.patch-cards-kind == 0
                                ? TextHorizontalAlignment.right
                                : TextHorizontalAlignment.center;
                        }
                        // BN4 bug line: plain purple text across the name cell.
                        if line.bug-plain : Text {
                            horizontal-stretch: 1;
                            text: line.bug;
                            font-size: 12px;
                            color: #b55ade;
                            vertical-alignment: center;
                        }
                        if !line.bug-plain : HorizontalLayout {
                            horizontal-stretch: 1;
                            spacing: 8px;
                            alignment: start;
                            Text {
                                text: line.name;
                                font-size: 13px;
                                color: line.enabled ? Theme.text : Theme.text-muted;
                                vertical-alignment: center;
                            }
                            if line.mb != "" : Text {
                                text: line.mb;
                                font-size: 10px;
                                color: Theme.text-muted;
                                vertical-alignment: center;
                            }
                        }
                        if SaveView.patch-cards-kind == 0 : HorizontalLayout {
                            width: 180px;
                            alignment: start;
                            if line.ability != "" : VerticalLayout {
                                alignment: center;
                                Rectangle {
                                    background: !line.enabled ? #bdbdbd
                                        : (line.ability-debuff ? #b55ade : #ffbd18);
                                    border-radius: 6px;
                                    HorizontalLayout {
                                        padding-left: 8px;
                                        padding-right: 8px;
                                        padding-top: 2px;
                                        padding-bottom: 2px;
                                        Text {
                                            text: line.ability;
                                            font-size: 12px;
                                            color: black;
                                        }
                                    }
                                }
                            }
                        }
                        if SaveView.patch-cards-kind == 0 : HorizontalLayout {
                            width: 180px;
                            alignment: start;
                            if line.bug != "" : VerticalLayout {
                                alignment: center;
                                Rectangle {
                                    background: !line.enabled ? #bdbdbd
                                        : (line.bug-debuff ? #b55ade : #ffbd18);
                                    border-radius: 6px;
                                    HorizontalLayout {
                                        padding-left: 8px;
                                        padding-right: 8px;
                                        padding-top: 2px;
                                        padding-bottom: 2px;
                                        Text {
                                            text: line.bug;
                                            font-size: 12px;
                                            color: black;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        // Patch-card editor: the registered list (same flattened
        // lines the viewer renders, with per-card controls on each
        // first line) beside the card library. BN4's slot toggle
        // rides the same controls; its adds replace their own slot.
        if SaveView.save-kind == 2 && SaveView.editing : HorizontalLayout {
            vertical-stretch: 1;
            spacing: 8px;
            Pane {
                horizontal-stretch: 1;
                ListView {
                    x: 1px;
                    y: 4px;
                    width: parent.width - 2px;
                    height: parent.height - 8px;
                    for line in SaveView.patch-card-lines : Rectangle {
                        height: 30px;
                        background: Math.mod(line.zebra, 2) == 0 ? transparent : Theme.row-alt;
                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 6px;
                            Text {
                                width: 30px;
                                text: line.idx;
                                font-size: 11px;
                                color: Theme.text-muted;
                                vertical-alignment: center;
                            }
                            Text {
                                horizontal-stretch: 1;
                                text: line.bug-plain ? line.bug : line.name;
                                font-size: 13px;
                                color: line.bug-plain
                                    ? #b55ade
                                    : (line.enabled ? Theme.text : Theme.text-muted);
                                vertical-alignment: center;
                                overflow: elide;
                            }
                            if line.first && line.mb != "" : Text {
                                text: line.mb;
                                font-size: 10px;
                                color: Theme.text-muted;
                                vertical-alignment: center;
                            }
                            if line.first && SaveView.patch-cards-kind == 1 && line.name != "" : Rectangle {
                                width: 34px;
                                height: 22px;
                                y: (parent.height - self.height) / 2;
                                border-radius: 6px;
                                background: line.enabled ? #29a121 : Theme.btn-plate;
                                border-width: 1px;
                                border-color: Theme.input-border;
                                TouchArea {
                                    clicked => { SaveView.pc-edit-toggle(line.zebra); }
                                }
                                Text {
                                    width: 100%;
                                    height: 100%;
                                    text: "ON";
                                    font-size: 10px;
                                    color: line.enabled ? white : Theme.text-muted;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                            if line.first && SaveView.patch-cards-kind == 0 : Rectangle {
                                width: 24px;
                                height: 22px;
                                y: (parent.height - self.height) / 2;
                                border-radius: 6px;
                                background: pcup.has-hover ? Theme.hover : Theme.btn-plate;
                                border-width: 1px;
                                border-color: Theme.input-border;
                                pcup := TouchArea {
                                    clicked => { SaveView.pc-edit-move(line.zebra, -1); }
                                }
                                LIcon {
                                    width: 100%;
                                    height: 100%;
                                    text: Glyphs.chevron-up;
                                    font-size: 11px;
                                    color: Theme.text-muted;
                                }
                            }
                            if line.first && SaveView.patch-cards-kind == 0 : Rectangle {
                                width: 24px;
                                height: 22px;
                                y: (parent.height - self.height) / 2;
                                border-radius: 6px;
                                background: pcdn.has-hover ? Theme.hover : Theme.btn-plate;
                                border-width: 1px;
                                border-color: Theme.input-border;
                                pcdn := TouchArea {
                                    clicked => { SaveView.pc-edit-move(line.zebra, 1); }
                                }
                                LIcon {
                                    width: 100%;
                                    height: 100%;
                                    text: Glyphs.chevron-down;
                                    font-size: 11px;
                                    color: Theme.text-muted;
                                }
                            }
                            if line.first && (SaveView.patch-cards-kind == 0 || line.name != "") : Rectangle {
                                width: 24px;
                                height: 22px;
                                y: (parent.height - self.height) / 2;
                                border-radius: 6px;
                                background: pcrm.has-hover ? #ff525233 : Theme.btn-plate;
                                border-width: 1px;
                                border-color: pcrm.has-hover ? #ff5252aa : Theme.input-border;
                                pcrm := TouchArea {
                                    clicked => { SaveView.pc-edit-remove(line.zebra); }
                                }
                                LIcon {
                                    width: 100%;
                                    height: 100%;
                                    text: Glyphs.x;
                                    font-size: 10px;
                                    color: pcrm.has-hover ? #ff8a8a : Theme.text-muted;
                                }
                            }
                        }
                    }
                }
            }
            Pane {
                horizontal-stretch: 1;
                VerticalLayout {
                    padding: 8px;
                    spacing: 6px;
                    ChunkyInput {
                        placeholder: I18n.folder-edit-search;
                        edited(t) => { SaveView.edit-filter-edited(t); }
                    }
                    ListView {
                        vertical-stretch: 1;
                        for row[i] in SaveView.edit-library-rows : Rectangle {
                            height: 30px;
                            background: pcadd.has-hover && row.addable
                                ? Theme.hover
                                : (Math.mod(i, 2) == 0 ? transparent : Theme.row-alt);
                            pcadd := TouchArea {
                                clicked => {
                                    if (row.addable) {
                                        SaveView.pc-edit-add(i);
                                    }
                                }
                            }
                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                spacing: 8px;
                                Text {
                                    horizontal-stretch: 1;
                                    text: row.name;
                                    font-size: 13px;
                                    color: row.addable ? Theme.text : Theme.text-muted;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                                Text {
                                    width: 48px;
                                    text: row.mb;
                                    font-size: 11px;
                                    color: Theme.text-muted;
                                    vertical-alignment: center;
                                    horizontal-alignment: right;
                                }
                            }
                        }
                    }
                }
            }
        }

        // Auto Battle Data (save_view/abd): six
        // titled sections of chip rows (count ·
        // icon · name · element · ATK · MB).
        // ABD editor: the live deck preview (the viewer's own rows,
        // rebuilt from the staged counts) beside the use-count library.
        if SaveView.save-kind == 3 && SaveView.editing : HorizontalLayout {
            vertical-stretch: 1;
            spacing: 8px;
            Pane {
                horizontal-stretch: 1;
                ListView {
                    x: 1px;
                    y: 4px;
                    width: parent.width - 2px;
                    height: parent.height - 8px;
                    for row in SaveView.abd-rows : Rectangle {
                        height: row.is-header ? 30px : 32px;
                        background: row.is-header || Math.mod(row.zebra, 2) == 0
                            ? transparent : Theme.row-alt;
                        if row.is-header : HorizontalLayout {
                            padding-left: 10px;
                            padding-top: 8px;
                            Text {
                                text: row.title;
                                font-size: 12px;
                                color: Theme.text;
                                vertical-alignment: bottom;
                            }
                        }
                        if !row.is-header : HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 8px;
                            Text {
                                width: 24px;
                                text: row.chip.count;
                                font-size: 12px;
                                color: Theme.text-muted;
                                vertical-alignment: center;
                            }
                            VerticalLayout {
                                alignment: center;
                                Image {
                                    width: 24px;
                                    height: 24px;
                                    source: row.chip.icon;
                                    image-fit: contain;
                                    image-rendering: pixelated;
                                }
                            }
                            Text {
                                horizontal-stretch: 1;
                                text: row.chip.name;
                                font-size: 13px;
                                color: row.chip.is-empty ? Theme.text-muted : Theme.text;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                        }
                    }
                }
            }
            Pane {
                horizontal-stretch: 1;
                VerticalLayout {
                    padding: 8px;
                    spacing: 6px;
                    ChunkyInput {
                        placeholder: I18n.folder-edit-search;
                        edited(t) => { SaveView.edit-filter-edited(t); }
                    }
                    ListView {
                        vertical-stretch: 1;
                        for row[i] in SaveView.edit-abd-rows : Rectangle {
                            height: 32px;
                            background: Math.mod(i, 2) == 0 ? transparent : Theme.row-alt;
                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                spacing: 6px;
                                VerticalLayout {
                                    alignment: center;
                                    Image {
                                        width: 24px;
                                        height: 24px;
                                        source: row.icon;
                                        image-fit: contain;
                                        image-rendering: pixelated;
                                    }
                                }
                                Text {
                                    horizontal-stretch: 1;
                                    text: row.name;
                                    font-size: 13px;
                                    color: Theme.text;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                                Rectangle {
                                    width: 22px;
                                    height: 22px;
                                    y: (parent.height - self.height) / 2;
                                    border-radius: 6px;
                                    background: um.has-hover ? Theme.hover : Theme.btn-plate;
                                    border-width: 1px;
                                    border-color: Theme.input-border;
                                    um := TouchArea {
                                        clicked => { SaveView.abd-edit-used(i, -1); }
                                    }
                                    Text {
                                        width: 100%;
                                        height: 100%;
                                        text: "−";
                                        font-size: 13px;
                                        color: Theme.text;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                                Text {
                                    width: 26px;
                                    text: row.used;
                                    font-size: 13px;
                                    color: Theme.text;
                                    vertical-alignment: center;
                                    horizontal-alignment: center;
                                }
                                Rectangle {
                                    width: 22px;
                                    height: 22px;
                                    y: (parent.height - self.height) / 2;
                                    border-radius: 6px;
                                    background: up.has-hover ? Theme.hover : Theme.btn-plate;
                                    border-width: 1px;
                                    border-color: Theme.input-border;
                                    up := TouchArea {
                                        clicked => { SaveView.abd-edit-used(i, 1); }
                                    }
                                    Text {
                                        width: 100%;
                                        height: 100%;
                                        text: "+";
                                        font-size: 13px;
                                        color: Theme.text;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                                if row.has-sec : Rectangle {
                                    width: 22px;
                                    height: 22px;
                                    y: (parent.height - self.height) / 2;
                                    border-radius: 6px;
                                    background: sm.has-hover ? Theme.hover : Theme.btn-plate;
                                    border-width: 1px;
                                    border-color: Theme.input-border;
                                    sm := TouchArea {
                                        clicked => { SaveView.abd-edit-sec(i, -1); }
                                    }
                                    Text {
                                        width: 100%;
                                        height: 100%;
                                        text: "−";
                                        font-size: 13px;
                                        color: #2984de;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                                if row.has-sec : Text {
                                    width: 26px;
                                    text: row.sec;
                                    font-size: 13px;
                                    color: #2984de;
                                    vertical-alignment: center;
                                    horizontal-alignment: center;
                                }
                                if row.has-sec : Rectangle {
                                    width: 22px;
                                    height: 22px;
                                    y: (parent.height - self.height) / 2;
                                    border-radius: 6px;
                                    background: sp.has-hover ? Theme.hover : Theme.btn-plate;
                                    border-width: 1px;
                                    border-color: Theme.input-border;
                                    sp := TouchArea {
                                        clicked => { SaveView.abd-edit-sec(i, 1); }
                                    }
                                    Text {
                                        width: 100%;
                                        height: 100%;
                                        text: "+";
                                        font-size: 13px;
                                        color: #2984de;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        if SaveView.save-kind == 3 && !SaveView.editing : Pane {
            vertical-stretch: 1;
            ListView {
                x: 1px;
                y: 4px;
                width: parent.width - 2px;
                height: parent.height - 8px;
                for row in SaveView.abd-rows : Rectangle {
                    height: row.is-header ? 34px : 36px;
                    background: row.is-header || Math.mod(row.zebra, 2) == 0
                        ? transparent : Theme.row-alt;
                    if row.is-header : HorizontalLayout {
                        padding-left: 12px;
                        padding-top: 10px;
                        Text {
                            text: row.title;
                            font-size: 13px;
                            color: Theme.text;
                            vertical-alignment: bottom;
                        }
                    }
                    if !row.is-header && row.chip.has-accent : Rectangle {
                        x: 0;
                        y: 0;
                        width: 3px;
                        height: parent.height;
                        background: row.chip.accent;
                    }
                    if !row.is-header : HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        spacing: 10px;
                        Text {
                            width: 24px;
                            text: row.chip.count;
                            font-size: 13px;
                            color: row.chip.count == "1×" ? Theme.text-muted : Theme.text;
                            vertical-alignment: center;
                        }
                        VerticalLayout {
                            alignment: center;
                            Image {
                                width: 28px;
                                height: 28px;
                                source: row.chip.icon;
                                image-fit: contain;
                                image-rendering: pixelated;
                            }
                        }
                        Text {
                            horizontal-stretch: 1;
                            text: row.chip.name;
                            font-size: 13px;
                            color: row.chip.is-empty ? Theme.text-muted : Theme.text;
                            vertical-alignment: center;
                        }
                        VerticalLayout {
                            alignment: center;
                            Image {
                                width: 28px;
                                height: 28px;
                                source: row.chip.element-icon;
                                image-fit: contain;
                                image-rendering: pixelated;
                            }
                        }
                        Text {
                            width: 50px;
                            text: row.chip.power;
                            font-size: 13px;
                            color: Theme.text;
                            vertical-alignment: center;
                            horizontal-alignment: right;
                        }
                        if SaveView.folder-has-mb : Text {
                            width: 50px;
                            text: row.chip.mb;
                            font-size: 11px;
                            color: Theme.text;
                            vertical-alignment: center;
                            horizontal-alignment: right;
                        }
                    }
                }
            }
        }

        // Folder editor (save_view/folder.rs render_folder_edit,
        // condensed): per-slot folder rows with REG/TAG toggles +
        // reorder arrows + remove on the left, the owned-chip
        // library (click to add) with a filter on the right.
        if SaveView.save-kind == 1 && SaveView.editing : HorizontalLayout {
            vertical-stretch: 1;
            spacing: 8px;
            Pane {
                horizontal-stretch: 1;
                ListView {
                    x: 1px;
                    y: 4px;
                    width: parent.width - 2px;
                    height: parent.height - 8px;
                    for row[i] in SaveView.edit-folder-rows : Rectangle {
                        height: 36px;
                        background: Math.mod(i, 2) == 0 ? transparent : Theme.row-alt;
                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 6px;
                            VerticalLayout {
                                alignment: center;
                                Image {
                                    width: 28px;
                                    height: 28px;
                                    source: row.icon;
                                    image-fit: contain;
                                    image-rendering: pixelated;
                                }
                            }
                            Text {
                                horizontal-stretch: 1;
                                text: row.name;
                                font-size: 13px;
                                color: Theme.text;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                            Text {
                                width: 18px;
                                text: row.code;
                                font-size: 13px;
                                color: Theme.text;
                                vertical-alignment: center;
                            }
                            Rectangle {
                                width: 38px;
                                height: 24px;
                                y: (parent.height - self.height) / 2;
                                border-radius: 6px;
                                background: row.is-regular ? #ff42a5 : Theme.btn-plate;
                                border-width: 1px;
                                border-color: Theme.input-border;
                                TouchArea {
                                    clicked => { SaveView.edit-toggle-regular(i); }
                                }
                                Text {
                                    width: 100%;
                                    height: 100%;
                                    text: "REG";
                                    font-size: 10px;
                                    color: row.is-regular ? white : Theme.text-muted;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                            Rectangle {
                                width: 38px;
                                height: 24px;
                                y: (parent.height - self.height) / 2;
                                border-radius: 6px;
                                background: row.tag-count > 0 ? #29a121 : Theme.btn-plate;
                                border-width: 1px;
                                border-color: Theme.input-border;
                                TouchArea {
                                    clicked => { SaveView.edit-toggle-tag(i); }
                                }
                                Text {
                                    width: 100%;
                                    height: 100%;
                                    text: "TAG";
                                    font-size: 10px;
                                    color: row.tag-count > 0 ? white : Theme.text-muted;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                            Rectangle {
                                width: 26px;
                                height: 24px;
                                y: (parent.height - self.height) / 2;
                                border-radius: 6px;
                                background: upta.has-hover ? Theme.hover : Theme.btn-plate;
                                border-width: 1px;
                                border-color: Theme.input-border;
                                upta := TouchArea {
                                    clicked => { SaveView.edit-move(i, -1); }
                                }
                                LIcon {
                                    width: 100%;
                                    height: 100%;
                                    text: Glyphs.chevron-up;
                                    font-size: 12px;
                                    color: Theme.text-muted;
                                }
                            }
                            Rectangle {
                                width: 26px;
                                height: 24px;
                                y: (parent.height - self.height) / 2;
                                border-radius: 6px;
                                background: dnta.has-hover ? Theme.hover : Theme.btn-plate;
                                border-width: 1px;
                                border-color: Theme.input-border;
                                dnta := TouchArea {
                                    clicked => { SaveView.edit-move(i, 1); }
                                }
                                LIcon {
                                    width: 100%;
                                    height: 100%;
                                    text: Glyphs.chevron-down;
                                    font-size: 12px;
                                    color: Theme.text-muted;
                                }
                            }
                            Rectangle {
                                width: 26px;
                                height: 24px;
                                y: (parent.height - self.height) / 2;
                                border-radius: 6px;
                                background: rmta.has-hover ? #ff525233 : Theme.btn-plate;
                                border-width: 1px;
                                border-color: rmta.has-hover ? #ff5252aa : Theme.input-border;
                                rmta := TouchArea {
                                    clicked => { SaveView.edit-remove(i); }
                                }
                                LIcon {
                                    width: 100%;
                                    height: 100%;
                                    text: Glyphs.x;
                                    font-size: 11px;
                                    color: rmta.has-hover ? #ff8a8a : Theme.text-muted;
                                }
                            }
                        }
                    }
                }
            }
            Pane {
                horizontal-stretch: 1;
                VerticalLayout {
                    padding: 8px;
                    spacing: 6px;
                    ChunkyInput {
                        placeholder: I18n.folder-edit-search;
                        edited(t) => { SaveView.edit-filter-edited(t); }
                    }
                    ListView {
                        vertical-stretch: 1;
                        for row[i] in SaveView.edit-library-rows : Rectangle {
                            height: 32px;
                            background: addta.has-hover && row.addable
                                ? Theme.hover
                                : (Math.mod(i, 2) == 0 ? transparent : Theme.row-alt);
                            addta := TouchArea {
                                clicked => {
                                    if (row.addable) {
                                        SaveView.edit-add(i);
                                    }
                                }
                            }
                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                spacing: 8px;
                                VerticalLayout {
                                    alignment: center;
                                    Image {
                                        width: 24px;
                                        height: 24px;
                                        source: row.icon;
                                        image-fit: contain;
                                        image-rendering: pixelated;
                                    }
                                }
                                Text {
                                    horizontal-stretch: 1;
                                    text: row.name;
                                    font-size: 13px;
                                    color: row.addable ? Theme.text : Theme.text-muted;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                                Text {
                                    width: 18px;
                                    text: row.code;
                                    font-size: 13px;
                                    color: row.addable ? Theme.text : Theme.text-muted;
                                    vertical-alignment: center;
                                }
                                Text {
                                    width: 40px;
                                    text: row.power;
                                    font-size: 12px;
                                    color: Theme.text-muted;
                                    vertical-alignment: center;
                                    horizontal-alignment: right;
                                }
                                Text {
                                    width: 44px;
                                    text: row.mb;
                                    font-size: 11px;
                                    color: Theme.text-muted;
                                    vertical-alignment: center;
                                    horizontal-alignment: right;
                                }
                            }
                        }
                    }
                }
            }
        }

        // Folder list (save_view/folder.rs
        // render_folder): one row per (grouped)
        // chip — count, icon, name + REG/TAG,
        // element, code, ATK, MB, with the class
        // accent as a left stripe.
        if SaveView.save-kind == 1 && !SaveView.editing : Pane {
            vertical-stretch: 1;
            ListView {
                x: 1px;
                y: 4px;
                width: parent.width - 2px;
                height: parent.height - 8px;
                for row[i] in SaveView.folder-chips : Rectangle {
                    height: 36px;
                    background: Math.mod(i, 2) == 0 ? transparent : Theme.row-alt;
                    if row.has-accent : Rectangle {
                        x: 0;
                        y: 0;
                        width: 3px;
                        height: parent.height;
                        background: row.accent;
                    }
                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        spacing: 10px;
                        if SaveView.folder-grouped : Text {
                            width: 24px;
                            text: row.count;
                            font-size: 13px;
                            // "1×" is visual noise — mute it.
                            color: row.count == "1×" ? Theme.text-muted : Theme.text;
                            vertical-alignment: center;
                        }
                        VerticalLayout {
                            alignment: center;
                            Image {
                                width: 28px;
                                height: 28px;
                                source: row.icon;
                                image-fit: contain;
                                image-rendering: pixelated;
                            }
                        }
                        // name + badges hug left inside
                        // the stretching middle cell.
                        HorizontalLayout {
                            horizontal-stretch: 1;
                            spacing: 8px;
                            alignment: start;
                            Text {
                                text: row.name;
                                font-size: 13px;
                                color: row.is-empty ? Theme.text-muted : Theme.text;
                                vertical-alignment: center;
                            }
                            if row.is-regular : VerticalLayout {
                                alignment: center;
                                Badge { label: "REG"; tint: #ff42a5; }
                            }
                            if row.tag-count >= 1 : VerticalLayout {
                                alignment: center;
                                Badge { label: "TAG"; tint: #29a121; }
                            }
                            if row.tag-count >= 2 : VerticalLayout {
                                alignment: center;
                                Badge { label: "TAG"; tint: #29a121; }
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            Image {
                                width: 28px;
                                height: 28px;
                                source: row.element-icon;
                                image-fit: contain;
                                image-rendering: pixelated;
                            }
                        }
                        Text {
                            width: 22px;
                            text: row.code;
                            font-size: 13px;
                            color: Theme.text;
                            vertical-alignment: center;
                            horizontal-alignment: right;
                        }
                        Text {
                            width: 50px;
                            text: row.power;
                            font-size: 13px;
                            color: Theme.text;
                            vertical-alignment: center;
                            horizontal-alignment: right;
                        }
                        if SaveView.folder-has-mb : Text {
                            width: 50px;
                            text: row.mb;
                            font-size: 11px;
                            color: Theme.text;
                            vertical-alignment: center;
                            horizontal-alignment: right;
                        }
                    }
                }
            }
        }
        if SaveView.save-tabs.length == 0 : PanePrompt {
            vertical-stretch: 1;
            message: I18n.save-empty;
        }
    }
    if !SaveView.save-loaded : PanePrompt {
        message: I18n.save-empty;
        vertical-stretch: 1;
    }
}

export component AppWindow inherits Window {
    title: "Tango";
    preferred-width: 960px;
    preferred-height: 720px;
    min-width: 960px;
    min-height: 720px;
    background: Theme.bg;
    default-font-family: "Noto Sans";
    default-font-size: 13px;
    icon: @image-url("../../tango/src/icon.png");

    in property <[string]> games: [];
    in property <[string]> saves: [];
    in property <[string]> patches: [];
    in property <[string]> versions: [];
    in property <[ReplayRow]> replays: [];
    in property <[string]> replay-game-filters: [];
    in-out property <int> selected-replay-filter: 0;
    // Off by default: known-incomplete replays hide from the list.
    in-out property <bool> replay-show-incomplete: false;
    in property <string> replay-title: "";
    in property <[string]> replay-detail: [];
    // ---- replay video export ----
    in-out property <float> replay-export-scale: 0.0;
    in property <string> replay-export-scale-label: "lossless";
    in-out property <bool> replay-export-mute: false;
    in-out property <bool> replay-export-twosided: false;
    in property <bool> replay-exporting: false;
    in property <float> replay-export-progress: 0.0;
    in property <string> replay-export-status: "";
    in property <bool> replay-export-has-output: false;
    // ---- patches tab ----
    // The (filtered) patch list; selection drives the detail pane's
    // patch-* properties, all pushed from Rust.
    in property <[PatchRow]> patch-list: [];
    in-out property <int> selected-patch-item: -1;
    in property <string> patch-title: "";
    in property <string> patch-authors: "";
    in property <string> patch-license: "";
    in property <string> patch-source: "";
    in property <string> patch-supported-games: "—";
    in property <string> patch-readme: "";
    // Detail version picker rows ("v1.2.3"), newest first.
    in property <[string]> patch-versions: [];
    in-out property <int> selected-patch-version: -1;
    // Detail pane: is the shown patch a favorite (the toggle's state).
    in property <bool> patch-detail-favorite: false;
    // Manual repo sync in flight (the Update button disables itself).
    in property <bool> patches-updating: false;
    // ---- welcome / first-run overlay ----
    in-out property <bool> welcome-visible: false;
    in-out property <string> welcome-nickname: "";
    in property <string> welcome-roms-path: "";
    in property <string> welcome-roms-detected: "";
    in property <bool> welcome-has-roms: false;
    // Status beside the Update button: "Updating…" / "Update failed: …"
    // / the last-updated stamp.
    in property <string> patches-update-status: "";
    in property <bool> patches-status-error: false;
    in property <image> frame;
    in property <bool> in-session: false;
    in property <string> status: "";
    in property <[string]> languages: [];
    in property <string> app-version: "";
    in-out property <string> settings-nickname: "";
    in-out property <string> settings-data-path: "";
    in-out property <int> settings-language: -1;
    in-out property <int> settings-theme: 0;
    in-out property <float> settings-volume: 1.0;
    in property <string> settings-volume-label: "100%";
    in-out property <bool> fractional: false;
    // ---- settings parity (tango's tabs/settings.rs) ----
    in-out property <bool> settings-streamer: false;
    in-out property <string> settings-patch-repo: "";
    in-out property <bool> settings-patch-autoupdate: true;
    in-out property <bool> settings-fullscreen: false;
    in-out property <int> settings-video-filter: 0;
    in-out property <bool> settings-hide-border: false;
    // BNLC bezel art behind the emulator, when the volume is owned.
    in property <image> session-bg;
    in property <bool> session-bg-has: false;
    in-out property <bool> settings-updater-enabled: false;
    in-out property <bool> settings-prerelease: false;
    in property <string> about-updater-status: "";
    in property <bool> about-update-ready: false;
    in-out property <bool> settings-mute-bgm: false;
    in-out property <string> settings-matchmaking-endpoint: "";
    in-out property <int> settings-relay: 0;
    in-out property <bool> settings-show-opponent-setup: false;
    // About: CREDITS.md as pre-split lines (a ListView scrolls them).
    in property <[string]> about-credits: [];
    // 0 = singleplayer, 1 = replay (transport bar), 2 = PvP (telemetry
    // footer + reconnect/disconnect overlays).
    in property <int> session-kind: 0;
    // ---- PvP in-session HUD ----
    in property <string> pvp-stats: "";
    // Normalized slider position; frames = 2 + value × 8 (main.rs
    // clamps to tango-pvp's [2, 10]) — same mapping as the lobby's.
    in-out property <float> pvp-frame-delay: 0.0;
    in property <string> pvp-frame-delay-label: "2";
    in property <bool> pvp-reconnecting: false;
    // Fraction of the reconnect give-up window remaining (1 → 0).
    in property <float> pvp-reconnect-progress: 0.0;
    // The disconnect confirm modal (X / Escape on a live match).
    in-out property <bool> session-confirm-exit: false;
    // Setup drawers: 0 = closed, 1 = my setup (left), 2 = opponent
    // (right). One at a time — both render the shared SaveViewBody.
    in-out property <int> session-drawer: 0;
    // In-session quick-settings modal (the corner gear).
    in-out property <bool> session-settings-open: false;
    // Floating controls fade out after ~2.5 s of pointer idle
    // (main.rs owns the clock; overlays pin them visible).
    in property <bool> session-controls-visible: true;
    in property <bool> pvp-opponent-blind: false;
    // ---- navicust section ----
    // ---- save management (save_manage.rs) ----
    // Which form replaces the save-picker row: 0 = none, 1 = rename,
    // 2 = duplicate, 3 = confirm delete, 4 = new save.
    in-out property <int> save-action: 0;
    in-out property <string> save-action-draft: "";
    // New-save template picker (labels; values live in Rust).
    in property <[string]> save-template-options: [];
    in-out property <int> save-template-selected: -1;
    in property <string> save-delete-prompt-text: "";
    // The selected family has creatable templates (New save enables).
    in property <bool> save-new-enabled: false;
    // Netplay: the typed link code / direct command.
    in-out property <string> link-code: "";
    // ---- netplay lobby band (Phase B) ----
    // Visible whenever a netplay attempt is past Idle; it replaces the
    // whole idle strip (link-code input + Fight) at the bottom of the
    // Play tab. All values are pushed from main.rs's per-tick refresh.
    in property <bool> lobby-visible: false;
    // Terminal failure: red-wash the command pane, drop everything but
    // the status line and Leave.
    in property <bool> lobby-failed: false;
    // Refuse input without changing layout (match spinning up).
    in property <bool> lobby-inert: false;
    in property <string> lobby-status: "";
    // 0 = in-flight (muted), 1 = good (green), 2 = bad (red).
    in property <int> lobby-status-tone: 0;
    // Caption under the status: link code / direct target while
    // dialing, live ping once measured.
    in property <string> lobby-conn-detail: "";
    in property <string> lobby-local-nickname: "";
    in property <string> lobby-local-subline: "";
    in property <bool> lobby-local-ready: false;
    in property <string> lobby-remote-nickname: "—";
    in property <string> lobby-remote-subline: "—";
    in property <bool> lobby-remote-ready: false;
    in property <[string]> lobby-match-types: [];
    in-out property <int> lobby-selected-match-type: -1;
    // Normalized slider position; frames = 2 + value × 8 (main.rs maps
    // + clamps to tango-pvp's [2, 10]).
    in-out property <float> lobby-frame-delay: 0.0;
    in property <string> lobby-frame-delay-label: "2";
    in-out property <bool> lobby-blind: false;
    // 0 = Ready (commit), 1 = Unready (uncommit), 2 = Starting… (inert).
    in property <int> lobby-ready-state: 0;
    in property <bool> lobby-ready-enabled: false;
    in property <bool> lobby-suggest-enabled: false;
    // ---- input settings pane ----
    // Selected mapped key: index into the Rust-side MappedKey::ALL
    // order (Up,Down,Left,Right,A,B,L,R,Start,Select,SpeedUp); -1 =
    // none (the LCD shows the select hint).
    in property <int> input-selected: -1;
    // Bezel caption: the selected key's localized name.
    in property <string> input-selected-label: "";
    // Per-key "a binding is physically held right now" flags, same
    // order as input-selected — the live binding-test highlight.
    in property <[bool]> input-lit: [];
    // The selected key's bindings, as display chips on the LCD.
    in property <[InputChip]> input-chips: [];
    in property <bool> input-capturing: false;
    in property <bool> replay-paused: false;
    // Scrubber hover thumbnail (nearest captured keyframe).
    in property <image> replay-hover-thumb;
    in property <bool> replay-hover-has-thumb: false;
    in property <string> replay-progress: "";
    in property <float> replay-scrub-pos: 0.0;
    in property <float> replay-prefetch: 0.0;
    in property <[float]> replay-marks: [];
    in-out property <int> replay-speed: 1;
    in-out property <int> active-tab: 0;
    in-out property <int> settings-section: 0;
    in-out property <int> selected-game: -1;
    in-out property <int> selected-save: -1;
    in-out property <int> selected-patch: 0;
    in-out property <int> selected-version: -1;
    in-out property <int> selected-replay: -1;

    callback game-selected(int);
    callback patch-selected(int);
    callback version-selected(int);
    callback save-selected(int);
    // Save management (the ⋮ menu + the New save button + form flow).
    callback save-new-start();
    callback save-open-folder();
    callback save-duplicate-start();
    callback save-rename-start();
    callback save-delete-start();
    callback save-action-cancel();
    // One confirm for whichever form is open (Rust switches on
    // save-action and reads the draft / template pick).
    callback save-action-confirm();
    // New-save template picked — Rust may regenerate the suggested name.
    callback save-template-picked(int);
    callback replay-selected(int);
    callback replay-filter-selected(int);
    callback replay-opponent-edited(string);
    callback replay-incomplete-toggled(bool);
    callback replay-open-folder();
    callback replay-export-scale-edited(float);
    callback replay-export-start();
    callback replay-export-cancel();
    callback replay-export-open();
    // patches tab
    callback patch-list-selected(int);
    callback patch-detail-version-selected(int);
    callback patch-search-edited(string);
    callback patch-update-clicked();
    callback patch-favorite-toggle();
    callback patch-open-folder();
    callback patch-open-source();
    // welcome overlay
    callback welcome-continue();
    callback welcome-open-roms();
    callback welcome-rescan();
    callback play-clicked();
    callback fight-clicked();
    callback watch-clicked();
    callback toggle-pause();
    callback speed-selected(int);
    callback scrub-started();
    // Pointer hovering the scrubber at this fraction (thumbnail fetch).
    callback scrub-hover(float);
    callback scrub-moved(float);
    callback scrub-committed(float);
    callback stop-clicked();
    callback key-event(string, bool);
    // PvP in-session HUD.
    callback pvp-frame-delay-changed(float);
    callback session-drawer-changed(int);
    // Any pointer motion over the session view — feeds the idle timer.
    callback session-pointer-moved();
    // The confirm modal's / reconnect overlay's Disconnect: tear the
    // session down for real (stop-clicked only *requests*, and gets
    // gated behind the modal while a match is live).
    callback exit-confirmed();
    callback nickname-changed(string);
    callback language-selected(int);
    callback theme-selected(int);
    callback volume-changed(float);
    callback fractional-changed(bool);
    callback data-path-changed(string);
    // settings parity
    callback streamer-changed(bool);
    callback patch-repo-changed(string);
    callback patch-autoupdate-changed(bool);
    callback fullscreen-changed(bool);
    callback video-filter-changed(int);
    callback hide-border-changed(bool);
    callback updater-enabled-changed(bool);
    callback prerelease-changed(bool);
    callback update-now();
    callback mute-bgm-changed(bool);
    callback matchmaking-endpoint-changed(string);
    callback relay-changed(int);
    callback show-opponent-setup-changed(bool);
    // input settings pane
    callback input-key-selected(int);
    callback input-binding-remove(int);
    callback input-capture-start();
    callback input-capture-cancel();
    callback input-reset();
    // Lobby band actions.
    callback lobby-leave();
    callback lobby-ready();
    callback lobby-unready();
    callback match-type-selected(int);
    callback frame-delay-changed(float);
    callback blind-toggled(bool);
    callback suggest-delay();

    if !root.in-session : VerticalLayout {
        width: 100%;
        height: 100%;

        // ---- top bar (hud_bar: gradient plate + shadow) ----
        Rectangle {
            background: Theme.light
                ? @linear-gradient(180deg, #fbf7ea 0%, #e8e2cd 100%)
                : @linear-gradient(180deg, #1b1e20 0%, #131516 100%);
            drop-shadow-blur: 10px;
            drop-shadow-color: Theme.light ? #00000030 : #00000080;
            drop-shadow-offset-y: 2px;
            HorizontalLayout {
                padding-top: 10px;
                padding-bottom: 10px;
                padding-left: 8px;
                padding-right: 8px;
                spacing: 8px;
                Rectangle {
                    width: 44px;
                    Image {
                        source: @image-url("../../tango/src/icon.png");
                        width: 28px;
                        height: 28px;
                        image-fit: contain;
                    }
                }
                PillTab {
                    glyph: Glyphs.gamepad;
                    label: I18n.tab-play;
                    active: root.active-tab == 0;
                    clicked => { root.active-tab = 0; }
                }
                PillTab {
                    glyph: Glyphs.film;
                    label: I18n.tab-replays;
                    active: root.active-tab == 1;
                    clicked => { root.active-tab = 1; }
                }
                Rectangle { horizontal-stretch: 1; }
                Text {
                    text: root.status;
                    font-size: 11px;
                    color: Theme.text-muted;
                    vertical-alignment: center;
                }
                PillTab {
                    glyph: Glyphs.puzzle;
                    label: "";
                    active: root.active-tab == 2;
                    clicked => { root.active-tab = 2; }
                }
                PillTab {
                    glyph: Glyphs.settings;
                    label: "";
                    active: root.active-tab == 3;
                    clicked => { root.active-tab = 3; }
                }
            }
        }
        Scanline { }

        // ---- body over the (approximated) backdrop wash ----
        Rectangle {
            background: Theme.light
                ? @linear-gradient(180deg, #f7f2e2 0%, #f3eedc 45%)
                : @linear-gradient(180deg, #12171a 0%, #0e1011 45%);
            vertical-stretch: 1;

            // Play
            if root.active-tab == 0 : VerticalLayout {
                width: 100%;
                height: 100%;

                VerticalLayout {
                    padding: 8px;
                    spacing: 8px;
                    vertical-stretch: 1;

                    // selector strip
                    Pane {
                        VerticalLayout {
                            padding: 12px;
                            spacing: 6px;
                            HorizontalLayout {
                                spacing: 8px;
                                Picker {
                                    model: root.games;
                                    placeholder: I18n.play-no-game;
                                    current <=> root.selected-game;
                                    horizontal-stretch: 3;
                                    selected(i) => {
                                        root.selected-save = -1;
                                        root.game-selected(i);
                                    }
                                }
                                Picker {
                                    model: root.patches;
                                    placeholder: I18n.play-no-patch;
                                    enabled: root.selected-game >= 0 && root.patches.length > 1;
                                    current <=> root.selected-patch;
                                    horizontal-stretch: 2;
                                    selected(i) => { root.patch-selected(i); }
                                }
                                Picker {
                                    model: root.versions;
                                    placeholder: "—";
                                    enabled: root.versions.length > 0;
                                    current <=> root.selected-version;
                                    width: 100px;
                                    selected(i) => { root.version-selected(i); }
                                }
                            }
                            // Save row: [New save][picker][⋮] at rest, or
                            // whichever management form is in flight
                            // (save_manage.rs; state = save-action).
                            if root.save-action == 0 : HorizontalLayout {
                                spacing: 8px;
                                NeutralButton {
                                    glyph: Glyphs.file-plus;
                                    enabled: root.save-new-enabled;
                                    clicked => { root.save-new-start(); }
                                }
                                Picker {
                                    model: root.saves;
                                    placeholder: I18n.play-no-save;
                                    current <=> root.selected-save;
                                    horizontal-stretch: 1;
                                    selected(i) => { root.save-selected(i); }
                                }
                                Rectangle {
                                    width: 42px;
                                    menu-btn := NeutralButton {
                                        width: 100%;
                                        height: 100%;
                                        glyph: Glyphs.ellipsis-v;
                                        enabled: root.selected-save >= 0;
                                        clicked => { actions-menu.show(); }
                                    }
                                    actions-menu := PopupWindow {
                                        x: parent.width - 180px;
                                        y: parent.height + 4px;
                                        width: 180px;
                                        Rectangle {
                                            background: Theme.bg;
                                            border-width: 1px;
                                            border-color: Theme.input-border;
                                            border-radius: 8px;
                                            VerticalLayout {
                                                padding: 4px;
                                                MenuRow {
                                                    label: I18n.save-open-folder;
                                                    clicked => { root.save-open-folder(); }
                                                }
                                                MenuRow {
                                                    label: I18n.save-duplicate;
                                                    clicked => { root.save-duplicate-start(); }
                                                }
                                                MenuRow {
                                                    label: I18n.save-rename;
                                                    clicked => { root.save-rename-start(); }
                                                }
                                                MenuRow {
                                                    label: I18n.save-delete;
                                                    danger: true;
                                                    clicked => { root.save-delete-start(); }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                            // Rename / duplicate: name field + cancel + confirm.
                            if root.save-action == 1 || root.save-action == 2 : HorizontalLayout {
                                spacing: 8px;
                                ChunkyInput {
                                    horizontal-stretch: 1;
                                    text <=> root.save-action-draft;
                                    placeholder: I18n.save-name-placeholder;
                                    accepted(t) => { root.save-action-confirm(); }
                                }
                                NeutralTextButton {
                                    label: I18n.save-action-cancel;
                                    clicked => { root.save-action-cancel(); }
                                }
                                PrimaryButton {
                                    label: root.save-action == 1 ? I18n.save-rename-confirm : I18n.save-duplicate;
                                    enabled: root.save-action-draft != "";
                                    pad-v: 5px;
                                    pad-h: 12px;
                                    clicked => { root.save-action-confirm(); }
                                }
                            }
                            // Delete: named prompt + cancel + red confirm.
                            if root.save-action == 3 : HorizontalLayout {
                                spacing: 8px;
                                Text {
                                    horizontal-stretch: 1;
                                    text: root.save-delete-prompt-text;
                                    font-size: 13px;
                                    color: Theme.text-muted;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                                NeutralTextButton {
                                    label: I18n.save-action-cancel;
                                    clicked => { root.save-action-cancel(); }
                                }
                                DangerTextButton {
                                    label: I18n.save-delete-confirm;
                                    clicked => { root.save-action-confirm(); }
                                }
                            }
                            // New save: template picker + name + cancel + create.
                            if root.save-action == 4 : HorizontalLayout {
                                spacing: 8px;
                                Picker {
                                    width: 220px;
                                    model: root.save-template-options;
                                    placeholder: I18n.save-template-pick;
                                    current <=> root.save-template-selected;
                                    selected(i) => { root.save-template-picked(i); }
                                }
                                ChunkyInput {
                                    horizontal-stretch: 1;
                                    text <=> root.save-action-draft;
                                    placeholder: I18n.save-name-placeholder;
                                    accepted(t) => { root.save-action-confirm(); }
                                }
                                NeutralTextButton {
                                    label: I18n.save-action-cancel;
                                    clicked => { root.save-action-cancel(); }
                                }
                                PrimaryButton {
                                    label: I18n.save-new-confirm;
                                    enabled: root.save-action-draft != "" && root.save-template-selected >= 0;
                                    pad-v: 5px;
                                    pad-h: 12px;
                                    clicked => { root.save-action-confirm(); }
                                }
                            }
                        }
                    }

                    // save body
                    if root.selected-save >= 0 : VerticalLayout {
                        spacing: 8px;
                        vertical-stretch: 1;
                        Pane {
                            HorizontalLayout {
                                padding: 12px;
                                spacing: 8px;
                                Text {
                                    text: root.selected-save >= 0 && root.selected-save < root.saves.length
                                        ? root.saves[root.selected-save]
                                        : "";
                                    font-size: 15px;
                                    color: Theme.text;
                                    vertical-alignment: center;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                }
                                PrimaryButton {
                                    glyph: Glyphs.play;
                                    label: I18n.play-play;
                                    pad-v: 4px;
                                    pad-h: 10px;
                                    clicked => { root.play-clicked(); }
                                }
                            }
                        }
                        // ---- save viewer (read-only) ----
                        // The whole viewer lives in SaveViewBody +
                        // the SaveView global so the play tab, the
                        // replay tab, and the in-session setup
                        // drawers can all render the same models.
                        SaveViewBody {
                            vertical-stretch: 1;
                        }
                    }
                    if root.selected-save < 0 : Rectangle {
                        vertical-stretch: 1;
                        Panel {
                            width: min(520px, parent.width - 48px);
                            height: content.preferred-height;
                            content := VerticalLayout {
                                padding: 28px;
                                spacing: 8px;
                                alignment: center;
                                LIcon {
                                    text: Glyphs.info;
                                    font-size: 28px;
                                    color: Theme.primary;
                                }
                                Text {
                                    text: root.games.length == 0
                                        ? I18n.empty-no-roms-title
                                        : I18n.empty-select-title;
                                    font-size: 18px;
                                    color: Theme.text;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    // The select-a-game body has no tango key — stays English.
                                    text: root.games.length == 0
                                        ? I18n.empty-no-roms-body
                                        : "Pick a game and one of its saves above, then hit Play.";
                                    font-size: 11px;
                                    color: Theme.text-muted;
                                    horizontal-alignment: center;
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }
                }

                // bottom band, edge-to-edge. Two variants as sibling
                // conditionals (NOT branches inside one Rectangle —
                // that would merge both branches' height constraints
                // and leave a dead zone under whichever is active).
                Scanline { }
                // Idle strip: link code / direct command entry + the
                // Fight CTA. Yields to the lobby band while a netplay
                // attempt is live.
                if !root.lobby-visible : Rectangle {
                    background: Theme.light
                        ? @linear-gradient(180deg, #fbf7ea 0%, #e8e2cd 100%)
                        : @linear-gradient(180deg, #1b1e20 0%, #131516 100%);
                    HorizontalLayout {
                        padding-top: 10px;
                        padding-bottom: 10px;
                        padding-left: 8px;
                        padding-right: 8px;
                        spacing: 10px;
                        ChunkyInput {
                            height: 40px;
                            horizontal-stretch: 1;
                            text <=> root.link-code;
                            placeholder: I18n.play-link-code;
                            // Streamer privacy: viewers must not read the code.
                            masked: root.settings-streamer;
                            accepted(t) => { root.fight-clicked(); }
                        }
                        PrimaryButton {
                            glyph: Glyphs.swords;
                            label: I18n.play-fight;
                            // No code required — an empty input makes
                            // Fight generate a random one (main.rs).
                            enabled: root.selected-game >= 0
                                && root.selected-save >= 0;
                            pad-v: 10px;
                            pad-h: 22px;
                            text-size: 15px;
                            height: 40px;
                            clicked => { root.fight-clicked(); }
                        }
                    }
                }

                // Lobby band (tango's tabs/play/lobby.rs): the matchup
                // hero (side cards + VS) over the command bar. The save
                // view above stays live throughout.
                if root.lobby-visible : Rectangle {
                    background: Theme.light
                        ? @linear-gradient(180deg, #fbf7ea 0%, #e8e2cd 100%)
                        : @linear-gradient(180deg, #1b1e20 0%, #131516 100%);
                    VerticalLayout {
                        padding: 8px;
                        spacing: 8px;

                        // matchup pane
                        Pane {
                            HorizontalLayout {
                                padding: 12px;
                                spacing: 12px;
                                LobbySideCard {
                                    horizontal-stretch: 1;
                                    role-label: I18n.lobby-you;
                                    nickname: root.lobby-local-nickname;
                                    subline: root.lobby-local-subline;
                                    ready: root.lobby-local-ready;
                                }
                                // tango draws a canvas "VS" splitter
                                // here; a plain centered VS stands in
                                // for now. TODO(lobby-vs): port the
                                // angled splitter.
                                Text {
                                    text: "VS";
                                    font-size: 15px;
                                    color: Theme.text-muted;
                                    vertical-alignment: center;
                                }
                                LobbySideCard {
                                    horizontal-stretch: 1;
                                    role-label: I18n.lobby-opponent;
                                    nickname: root.lobby-remote-nickname;
                                    subline: root.lobby-remote-subline;
                                    ready: root.lobby-remote-ready;
                                }
                            }
                        }

                        // command pane: Leave | status stack | match
                        // settings cluster | Ready. On failure the pane
                        // powers down: settings + Ready disappear and a
                        // faint red wash sets the mood.
                        Pane {
                            background: root.lobby-failed ? #ff525214 : Theme.plate;
                            HorizontalLayout {
                                padding: 12px;
                                spacing: 16px;
                                VerticalLayout {
                                    alignment: center;
                                    DangerIconButton {
                                        glyph: Glyphs.log-out;
                                        enabled: !root.lobby-inert || root.lobby-failed;
                                        clicked => { root.lobby-leave(); }
                                    }
                                }
                                VerticalLayout {
                                    alignment: center;
                                    spacing: 4px;
                                    horizontal-stretch: 1;
                                    Text {
                                        text: root.lobby-status;
                                        font-size: 13px;
                                        color: root.lobby-status-tone == 2
                                            ? Theme.danger
                                            : (root.lobby-status-tone == 1 ? Theme.primary : Theme.text-muted);
                                        overflow: elide;
                                    }
                                    if root.lobby-conn-detail != "" : Text {
                                        text: root.lobby-conn-detail;
                                        font-size: 11px;
                                        color: Theme.text-muted;
                                        overflow: elide;
                                    }
                                }
                                if !root.lobby-failed : HorizontalLayout {
                                    spacing: 16px;
                                    Labeled {
                                        label: I18n.lobby-match-type;
                                        Picker {
                                            width: 150px;
                                            model: root.lobby-match-types;
                                            placeholder: "—";
                                            enabled: !root.lobby-inert;
                                            current <=> root.lobby-selected-match-type;
                                            selected(i) => { root.match-type-selected(i); }
                                        }
                                    }
                                    Labeled {
                                        label: I18n.lobby-frame-delay;
                                        HorizontalLayout {
                                            spacing: 8px;
                                            VerticalLayout {
                                                alignment: center;
                                                ChunkySlider {
                                                    width: 120px;
                                                    enabled: !root.lobby-inert;
                                                    value <=> root.lobby-frame-delay;
                                                    changed(v) => { root.frame-delay-changed(v); }
                                                }
                                            }
                                            Text {
                                                text: root.lobby-frame-delay-label;
                                                width: 16px;
                                                font-size: 13px;
                                                color: Theme.text;
                                                vertical-alignment: center;
                                            }
                                            NeutralButton {
                                                glyph: Glyphs.wand;
                                                enabled: root.lobby-suggest-enabled;
                                                clicked => { root.suggest-delay(); }
                                            }
                                        }
                                    }
                                    VerticalLayout {
                                        alignment: center;
                                        ChunkyCheckbox {
                                            label: I18n.lobby-blind;
                                            enabled: !root.lobby-inert;
                                            checked <=> root.lobby-blind;
                                            toggled(b) => { root.blind-toggled(b); }
                                        }
                                    }
                                    VerticalLayout {
                                        alignment: center;
                                        PrimaryButton {
                                            width: 122px;
                                            glyph: root.lobby-ready-state == 0
                                                ? Glyphs.check
                                                : (root.lobby-ready-state == 1 ? Glyphs.x : Glyphs.play);
                                            label: root.lobby-ready-state == 0
                                                ? I18n.lobby-ready
                                                : (root.lobby-ready-state == 1 ? I18n.lobby-unready : I18n.lobby-starting);
                                            enabled: root.lobby-ready-enabled;
                                            pad-v: 8px;
                                            pad-h: 12px;
                                            text-size: 15px;
                                            clicked => {
                                                if (root.lobby-ready-state == 0) {
                                                    root.lobby-ready();
                                                } else if (root.lobby-ready-state == 1) {
                                                    root.lobby-unready();
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // Replays
            if root.active-tab == 1 : VerticalLayout {
                width: 100%;
                height: 100%;
                padding: 8px;
                spacing: 8px;
                Pane {
                    HorizontalLayout {
                        padding: 12px;
                        spacing: 8px;
                        Picker {
                            model: root.replay-game-filters;
                            placeholder: I18n.replays-all-games;
                            current <=> root.selected-replay-filter;
                            width: 220px;
                            selected(i) => { root.replay-filter-selected(i); }
                        }
                        ChunkyInput {
                            width: 220px;
                            placeholder: I18n.replays-opponent-placeholder;
                            edited(t) => { root.replay-opponent-edited(t); }
                        }
                        VerticalLayout {
                            alignment: center;
                            ChunkyCheckbox {
                                label: I18n.replays-show-incomplete;
                                checked <=> root.replay-show-incomplete;
                                toggled(b) => { root.replay-incomplete-toggled(b); }
                            }
                        }
                        Rectangle { horizontal-stretch: 1; }
                    }
                }
                HorizontalLayout {
                    spacing: 8px;
                    vertical-stretch: 1;

                    // replay list (fixed 360, like tango's)
                    Pane {
                        width: 360px;
                        if root.replays.length == 0 : Text {
                            width: 100%;
                            height: 100%;
                            // no tango key ("no replays" state) — stays English
                            text: "No replays found";
                            color: Theme.text-muted;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        if root.replays.length > 0 : ListView {
                            x: 4px;
                            y: 8px;
                            width: parent.width - 8px;
                            height: parent.height - 16px;
                            for entry[i] in root.replays : Rectangle {
                                height: 48px;
                                border-radius: 4px;
                                background: root.selected-replay == i
                                    ? @linear-gradient(180deg, #ffd23d 0%, #e6b520 100%)
                                    : (rta.has-hover
                                        ? Theme.hover
                                        : (Math.mod(i, 2) == 0 ? transparent : Theme.row-alt));
                                rta := TouchArea {
                                    clicked => {
                                        root.selected-replay = i;
                                        root.replay-selected(i);
                                    }
                                }
                                VerticalLayout {
                                    padding-left: 10px;
                                    padding-right: 10px;
                                    padding-top: 6px;
                                    padding-bottom: 6px;
                                    Text {
                                        text: entry.line1;
                                        font-size: 13px;
                                        color: root.selected-replay == i ? Theme.ink : Theme.text;
                                        overflow: elide;
                                    }
                                    Text {
                                        text: entry.line2;
                                        font-size: 11px;
                                        color: root.selected-replay == i ? Theme.ink : Theme.text-muted;
                                        overflow: elide;
                                    }
                                }
                            }
                        }
                    }

                    // detail
                    if root.selected-replay < 0 : PanePrompt {
                        horizontal-stretch: 1;
                        message: I18n.replays-select-prompt;
                    }
                    if root.selected-replay >= 0 : Pane {
                        horizontal-stretch: 1;
                        VerticalLayout {
                            padding: 12px;
                            spacing: 8px;
                            alignment: start;
                            HorizontalLayout {
                                spacing: 8px;
                                Text {
                                    text: root.replay-title;
                                    font-size: 18px;
                                    color: Theme.text;
                                    vertical-alignment: center;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                }
                                NeutralTextButton {
                                    label: I18n.save-open-folder;
                                    clicked => { root.replay-open-folder(); }
                                }
                                PrimaryButton {
                                    glyph: Glyphs.play;
                                    label: I18n.replays-watch;
                                    pad-v: 4px;
                                    pad-h: 10px;
                                    clicked => { root.watch-clicked(); }
                                }
                            }
                            VerticalLayout {
                                spacing: 3px;
                                for line in root.replay-detail : Text {
                                    text: line;
                                    font-size: 13px;
                                    color: Theme.text-muted;
                                    overflow: elide;
                                }
                            }
                            // Embedded read-only save view of the
                            // replay's local side (SaveView global —
                            // the timer re-points it at replay models
                            // while this tab is visible).
                            SaveViewBody {
                                vertical-stretch: 1;
                            }
                            // Video export (tabs/replays/export.rs):
                            // scale (0 = lossless .mkv), mute, two-sided;
                            // progress + cancel while a render runs.
                            if !root.replay-exporting : HorizontalLayout {
                                spacing: 10px;
                                Text {
                                    text: I18n.replays-export-scale;
                                    font-size: 11px;
                                    color: Theme.text-muted;
                                    vertical-alignment: center;
                                }
                                VerticalLayout {
                                    alignment: center;
                                    ChunkySlider {
                                        width: 110px;
                                        value <=> root.replay-export-scale;
                                        changed(v) => { root.replay-export-scale-edited(v); }
                                    }
                                }
                                Text {
                                    width: 62px;
                                    text: root.replay-export-scale-label;
                                    font-size: 12px;
                                    color: Theme.text;
                                    vertical-alignment: center;
                                }
                                ChunkyCheckbox {
                                    label: I18n.replays-export-disable-bgm;
                                    checked <=> root.replay-export-mute;
                                }
                                ChunkyCheckbox {
                                    label: I18n.replays-export-twosided;
                                    checked <=> root.replay-export-twosided;
                                }
                                Rectangle { horizontal-stretch: 1; }
                                if root.replay-export-has-output : NeutralTextButton {
                                    label: I18n.replays-export-open;
                                    clicked => { root.replay-export-open(); }
                                }
                                PrimaryButton {
                                    label: I18n.replays-export;
                                    pad-v: 5px;
                                    pad-h: 12px;
                                    clicked => { root.replay-export-start(); }
                                }
                            }
                            if root.replay-exporting : HorizontalLayout {
                                spacing: 10px;
                                Rectangle {
                                    height: 6px;
                                    y: (parent.height - self.height) / 2;
                                    horizontal-stretch: 1;
                                    border-radius: 3px;
                                    background: #ffffff14;
                                    Rectangle {
                                        x: 0;
                                        height: 100%;
                                        width: parent.width * max(0.0, min(1.0, root.replay-export-progress));
                                        border-radius: 3px;
                                        background: #4caf50;
                                    }
                                }
                                NeutralTextButton {
                                    label: I18n.replays-export-cancel;
                                    clicked => { root.replay-export-cancel(); }
                                }
                            }
                            if root.replay-export-status != "" : Text {
                                text: root.replay-export-status;
                                font-size: 12px;
                                color: Theme.text-muted;
                                overflow: elide;
                            }
                        }
                    }
                }
            }

            // Patches
            if root.active-tab == 2 : VerticalLayout {
                width: 100%;
                height: 100%;
                padding: 8px;
                spacing: 8px;

                // Filter strip: name/title search on the left; sync
                // status + Update button on the right.
                Pane {
                    HorizontalLayout {
                        padding: 12px;
                        spacing: 8px;
                        ChunkyInput {
                            width: 260px;
                            placeholder: I18n.patches-search-placeholder;
                            edited(t) => { root.patch-search-edited(t); }
                        }
                        // The status takes all the slack and right-
                        // aligns beside the button; a long error
                        // elides instead of pushing the button off
                        // the pane.
                        Text {
                            text: root.patches-update-status;
                            font-size: 11px;
                            color: root.patches-status-error ? Theme.danger : Theme.text-muted;
                            vertical-alignment: center;
                            horizontal-alignment: right;
                            overflow: elide;
                            horizontal-stretch: 1;
                        }
                        PrimaryButton {
                            glyph: Glyphs.refresh-cw;
                            label: I18n.patches-update;
                            enabled: !root.patches-updating;
                            clicked => { root.patch-update-clicked(); }
                        }
                    }
                }
                HorizontalLayout {
                    spacing: 8px;
                    vertical-stretch: 1;

                    // patch list (fixed 360, like the replay list)
                    Pane {
                        width: 360px;
                        if root.patch-list.length == 0 : Text {
                            width: 100%;
                            height: 100%;
                            // no tango key ("no patches" state) — stays English
                            text: "No patches found";
                            color: Theme.text-muted;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        if root.patch-list.length > 0 : ListView {
                            x: 4px;
                            y: 8px;
                            width: parent.width - 8px;
                            height: parent.height - 16px;
                            for entry[i] in root.patch-list : Rectangle {
                                height: 48px;
                                border-radius: 4px;
                                background: root.selected-patch-item == i
                                    ? @linear-gradient(180deg, #ffd23d 0%, #e6b520 100%)
                                    : (plta.has-hover
                                        ? Theme.hover
                                        : (Math.mod(i, 2) == 0 ? transparent : Theme.row-alt));
                                plta := TouchArea {
                                    clicked => {
                                        root.selected-patch-item = i;
                                        root.patch-list-selected(i);
                                    }
                                }
                                VerticalLayout {
                                    padding-left: 10px;
                                    padding-right: 10px;
                                    padding-top: 6px;
                                    padding-bottom: 6px;
                                    HorizontalLayout {
                                        spacing: 5px;
                                        alignment: start;
                                        if entry.favorite : Text {
                                            text: "★";
                                            font-size: 13px;
                                            // Favorite gold, readable on both washes.
                                            color: root.selected-patch-item == i ? Theme.ink : #ffc700;
                                            vertical-alignment: center;
                                        }
                                        Text {
                                            text: entry.title;
                                            font-size: 13px;
                                            color: root.selected-patch-item == i ? Theme.ink : Theme.text;
                                            overflow: elide;
                                        }
                                    }
                                    Text {
                                        text: entry.authors;
                                        font-size: 11px;
                                        color: root.selected-patch-item == i ? Theme.ink : Theme.text-muted;
                                        overflow: elide;
                                    }
                                }
                            }
                        }
                    }

                    // detail
                    if root.selected-patch-item < 0 : PanePrompt {
                        horizontal-stretch: 1;
                        message: I18n.patches-select-prompt;
                    }
                    if root.selected-patch-item >= 0 : Pane {
                        horizontal-stretch: 1;
                        VerticalLayout {
                            padding: 12px;
                            spacing: 8px;
                            HorizontalLayout {
                                spacing: 8px;
                                Text {
                                    text: root.patch-title;
                                    font-size: 18px;
                                    color: Theme.text;
                                    vertical-alignment: center;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                }
                                NeutralTextButton {
                                    label: root.patch-detail-favorite
                                        ? "★ " + I18n.patches-unfavorite
                                        : "☆ " + I18n.patches-favorite;
                                    clicked => { root.patch-favorite-toggle(); }
                                }
                                NeutralTextButton {
                                    label: I18n.patches-open-folder;
                                    clicked => { root.patch-open-folder(); }
                                }
                                Picker {
                                    width: 140px;
                                    model: root.patch-versions;
                                    placeholder: "—";
                                    current <=> root.selected-patch-version;
                                    selected(i) => { root.patch-detail-version-selected(i); }
                                }
                            }
                            VerticalLayout {
                                spacing: 3px;
                                if root.patch-authors != "" : HorizontalLayout {
                                    spacing: 6px;
                                    Text {
                                        text: I18n.patches-details-authors;
                                        font-size: 11px;
                                        color: Theme.text-muted;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: root.patch-authors;
                                        font-size: 11px;
                                        color: Theme.text;
                                        vertical-alignment: center;
                                        overflow: elide;
                                        horizontal-stretch: 1;
                                    }
                                }
                                if root.patch-license != "" : HorizontalLayout {
                                    spacing: 6px;
                                    Text {
                                        text: I18n.patches-details-license;
                                        font-size: 11px;
                                        color: Theme.text-muted;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: root.patch-license;
                                        font-size: 11px;
                                        color: Theme.text;
                                        vertical-alignment: center;
                                        overflow: elide;
                                        horizontal-stretch: 1;
                                    }
                                }
                                if root.patch-source != "" : HorizontalLayout {
                                    spacing: 6px;
                                    Text {
                                        text: I18n.patches-details-source;
                                        font-size: 11px;
                                        color: Theme.text-muted;
                                        vertical-alignment: center;
                                    }
                                    // Clickable: opens the URL in the browser.
                                    src-link := Text {
                                        text: root.patch-source;
                                        font-size: 11px;
                                        color: srcta.has-hover ? Theme.primary : Theme.text;
                                        vertical-alignment: center;
                                        overflow: elide;
                                        horizontal-stretch: 1;
                                        srcta := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { root.patch-open-source(); }
                                        }
                                    }
                                }
                                // Supported games for the picked version.
                                HorizontalLayout {
                                    spacing: 6px;
                                    Text {
                                        text: I18n.patches-details-games;
                                        font-size: 11px;
                                        color: Theme.text-muted;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: root.patch-supported-games;
                                        font-size: 11px;
                                        color: Theme.text;
                                        vertical-alignment: center;
                                        overflow: elide;
                                        horizontal-stretch: 1;
                                    }
                                }
                            }
                            // README as scrollable plain text — TODO:
                            // markdown rendering (slint has no markdown
                            // widget; tango parses it via iced's).
                            if root.patch-readme == "" : Text {
                                text: I18n.patches-readme-placeholder;
                                font-size: 11px;
                                color: Theme.text-muted;
                            }
                            if root.patch-readme != "" : Flickable {
                                vertical-stretch: 1;
                                viewport-height: readme-text.height;
                                readme-text := Text {
                                    x: 0;
                                    y: 0;
                                    width: parent.width;
                                    height: self.preferred-height;
                                    text: root.patch-readme;
                                    font-size: 13px;
                                    color: Theme.text;
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }
                }
            }

            // Settings
            if root.active-tab == 3 : HorizontalLayout {
                width: 100%;
                height: 100%;
                padding: 8px;
                spacing: 8px;
                Pane {
                    width: 160px;
                    VerticalLayout {
                        padding: 8px;
                        spacing: 4px;
                        PillTab {
                            glyph: Glyphs.sliders;
                            label: I18n.settings-general;
                            active: root.settings-section == 0;
                            clicked => { root.settings-section = 0; }
                        }
                        PillTab {
                            glyph: Glyphs.monitor;
                            label: I18n.settings-graphics;
                            active: root.settings-section == 1;
                            clicked => { root.settings-section = 1; }
                        }
                        PillTab {
                            glyph: Glyphs.volume;
                            label: I18n.settings-audio;
                            active: root.settings-section == 2;
                            clicked => { root.settings-section = 2; }
                        }
                        PillTab {
                            glyph: Glyphs.gamepad2;
                            label: I18n.settings-input;
                            active: root.settings-section == 3;
                            clicked => { root.settings-section = 3; }
                        }
                        PillTab {
                            glyph: Glyphs.globe;
                            label: I18n.settings-netplay;
                            active: root.settings-section == 4;
                            clicked => { root.settings-section = 4; }
                        }
                        PillTab {
                            glyph: Glyphs.info;
                            label: I18n.settings-about;
                            active: root.settings-section == 5;
                            clicked => { root.settings-section = 5; }
                        }
                        Rectangle { vertical-stretch: 1; }
                    }
                }
                Pane {
                    horizontal-stretch: 1;
                    if root.settings-section == 0 : VerticalLayout {
                        padding: 12px;
                        spacing: 14px;
                        alignment: start;
                        Labeled {
                            label: I18n.settings-nickname;
                            ChunkyInput {
                                width: 240px;
                                text <=> root.settings-nickname;
                                accepted(t) => { root.nickname-changed(t); }
                            }
                        }
                        Labeled {
                            label: I18n.settings-language;
                            Picker {
                                width: 240px;
                                model: root.languages;
                                placeholder: "—";
                                current <=> root.settings-language;
                                selected(i) => { root.language-selected(i); }
                            }
                        }
                        Labeled {
                            label: I18n.settings-theme;
                            Picker {
                                width: 240px;
                                model: [I18n.settings-theme-dark, I18n.settings-theme-light];
                                placeholder: "—";
                                current <=> root.settings-theme;
                                selected(i) => { root.theme-selected(i); }
                            }
                        }
                        Labeled {
                            label: I18n.settings-data-folder;
                            ChunkyInput {
                                width: 480px;
                                text <=> root.settings-data-path;
                                accepted(t) => { root.data-path-changed(t); }
                            }
                        }
                        ChunkyCheckbox {
                            label: I18n.settings-streamer-mode;
                            checked <=> root.settings-streamer;
                            toggled(b) => { root.streamer-changed(b); }
                        }
                        Labeled {
                            label: I18n.settings-patch-repo;
                            ChunkyInput {
                                width: 480px;
                                text <=> root.settings-patch-repo;
                                accepted(t) => { root.patch-repo-changed(t); }
                            }
                        }
                        ChunkyCheckbox {
                            label: I18n.settings-patch-autoupdate;
                            checked <=> root.settings-patch-autoupdate;
                            toggled(b) => { root.patch-autoupdate-changed(b); }
                        }
                        ChunkyCheckbox {
                            label: I18n.settings-enable-updater;
                            checked <=> root.settings-updater-enabled;
                            toggled(b) => { root.updater-enabled-changed(b); }
                        }
                        ChunkyCheckbox {
                            label: I18n.settings-allow-prerelease;
                            checked <=> root.settings-prerelease;
                            toggled(b) => { root.prerelease-changed(b); }
                        }
                    }
                    if root.settings-section == 1 : VerticalLayout {
                        padding: 12px;
                        spacing: 14px;
                        alignment: start;
                        ChunkyCheckbox {
                            label: I18n.settings-fullscreen;
                            checked <=> root.settings-fullscreen;
                            toggled(b) => { root.fullscreen-changed(b); }
                        }
                        ChunkyCheckbox {
                            label: I18n.settings-fractional;
                            checked <=> root.fractional;
                            toggled(b) => { root.fractional-changed(b); }
                        }
                        ChunkyCheckbox {
                            label: I18n.settings-hide-border;
                            checked <=> root.settings-hide-border;
                            toggled(b) => { root.hide-border-changed(b); }
                        }
                        Labeled {
                            label: I18n.settings-video-filter;
                            Picker {
                                width: 240px;
                                // Filter names are proper nouns — not localized
                                // (same as tango's picker).
                                model: ["—", "hq2x", "hq3x", "hq4x", "MMPX", "LCD"];
                                placeholder: "—";
                                current <=> root.settings-video-filter;
                                selected(i) => { root.video-filter-changed(i); }
                            }
                        }
                    }
                    if root.settings-section == 2 : VerticalLayout {
                        padding: 12px;
                        spacing: 14px;
                        alignment: start;
                        Labeled {
                            label: I18n.settings-volume;
                            HorizontalLayout {
                                spacing: 8px;
                                ChunkySlider {
                                    value <=> root.settings-volume;
                                    changed(v) => { root.volume-changed(v); }
                                }
                                Text {
                                    text: root.settings-volume-label;
                                    font-size: 13px;
                                    color: Theme.text;
                                    vertical-alignment: center;
                                }
                            }
                        }
                        ChunkyCheckbox {
                            label: I18n.settings-mute-bgm;
                            checked <=> root.settings-mute-bgm;
                            toggled(b) => { root.mute-bgm-changed(b); }
                        }
                    }
                    if root.settings-section == 4 : VerticalLayout {
                        padding: 12px;
                        spacing: 14px;
                        alignment: start;
                        Labeled {
                            label: I18n.settings-matchmaking-endpoint;
                            ChunkyInput {
                                width: 480px;
                                text <=> root.settings-matchmaking-endpoint;
                                accepted(t) => { root.matchmaking-endpoint-changed(t); }
                            }
                        }
                        Labeled {
                            label: I18n.settings-use-relay;
                            Picker {
                                width: 240px;
                                model: [I18n.settings-relay-auto, I18n.settings-relay-always, I18n.settings-relay-never];
                                placeholder: "—";
                                current <=> root.settings-relay;
                                selected(i) => { root.relay-changed(i); }
                            }
                        }
                        ChunkyCheckbox {
                            label: I18n.settings-show-opponent-setup;
                            checked <=> root.settings-show-opponent-setup;
                            toggled(b) => { root.show-opponent-setup-changed(b); }
                        }
                    }
                    if root.settings-section == 5 : VerticalLayout {
                        padding: 12px;
                        spacing: 8px;
                        Text {
                            text: "Tango NG";
                            font-size: 18px;
                            color: Theme.text;
                        }
                        Text {
                            text: root.app-version;
                            font-size: 11px;
                            color: Theme.text-muted;
                        }
                        if root.about-updater-status != "" : HorizontalLayout {
                            spacing: 10px;
                            alignment: start;
                            Text {
                                text: root.about-updater-status;
                                font-size: 12px;
                                color: Theme.text-muted;
                                vertical-alignment: center;
                            }
                            if root.about-update-ready : PrimaryButton {
                                label: I18n.updater-update-now;
                                pad-v: 4px;
                                pad-h: 10px;
                                clicked => { root.update-now(); }
                            }
                        }
                        // CREDITS.md, embedded at build time and split
                        // into lines in Rust (a wrapped Text inside a
                        // scrollable risks layout cycles; a line list
                        // scrolls for free).
                        ListView {
                            vertical-stretch: 1;
                            for line in root.about-credits : Text {
                                height: 20px;
                                text: line;
                                font-size: 12px;
                                color: Theme.text-muted;
                                overflow: elide;
                            }
                        }
                    }
                    // Input: the drawn GBA console shell (tango's
                    // settings_input). The FocusScope keeps keyboard
                    // focus while the pane is up so key events reach
                    // the shared key-event callback — Rust routes
                    // them to the capture flow when one is armed,
                    // else just into the held set for the live
                    // key-lights (no session can be active here).
                    if root.settings-section == 3 : FocusScope {
                        init => { self.focus(); }
                        key-pressed(event) => {
                            root.key-event(event.text, true);
                            accept
                        }
                        key-released(event) => {
                            root.key-event(event.text, false);
                            accept
                        }

                        VerticalLayout {
                            padding: 12px;
                            alignment: start;
                            HorizontalLayout {
                                alignment: center;
                                VerticalLayout {
                                    spacing: 14px;

                                    // The console shell: one lifted
                                    // plate with the GBA silhouette
                                    // (grip corners fuller than the
                                    // top).
                                    Rectangle {
                                        width: 560px;
                                        background: Theme.panel-bg;
                                        border-width: 1.5px;
                                        border-color: Theme.input-border;
                                        border-top-left-radius: 24px;
                                        border-top-right-radius: 24px;
                                        border-bottom-right-radius: 34px;
                                        border-bottom-left-radius: 34px;

                                        VerticalLayout {
                                            padding-top: 10px;
                                            padding-right: 18px;
                                            padding-bottom: 24px;
                                            padding-left: 18px;
                                            spacing: 10px;

                                            // Shoulders: L/R pills at the far edges.
                                            HorizontalLayout {
                                                GbaKey {
                                                    width: 84px;
                                                    height: 22px;
                                                    border-radius: 11px;
                                                    label: "L";
                                                    selected: root.input-selected == 6;
                                                    lit: root.input-lit[6];
                                                    clicked => { root.input-key-selected(6); }
                                                }
                                                Rectangle { horizontal-stretch: 1; }
                                                GbaKey {
                                                    width: 84px;
                                                    height: 22px;
                                                    border-radius: 11px;
                                                    label: "R";
                                                    selected: root.input-selected == 7;
                                                    lit: root.input-lit[7];
                                                    clicked => { root.input-key-selected(7); }
                                                }
                                            }

                                            // Face row: D-pad + Start/Select | LCD bezel | A/B.
                                            HorizontalLayout {
                                                VerticalLayout {
                                                    alignment: center;
                                                    VerticalLayout {
                                                        spacing: 16px;

                                                        // D-pad: four arms around an inert
                                                        // hub; outer corners take the big
                                                        // radius so the cross reads as one
                                                        // molded pad, 2px seams keep each
                                                        // arm clickable on its own.
                                                        VerticalLayout {
                                                            spacing: 2px;
                                                            HorizontalLayout {
                                                                spacing: 2px;
                                                                Rectangle { width: 34px; height: 34px; }
                                                                GbaKey {
                                                                    width: 34px;
                                                                    height: 34px;
                                                                    glyph: Glyphs.chevron-up;
                                                                    text-size: 16px;
                                                                    border-top-left-radius: 10px;
                                                                    border-top-right-radius: 10px;
                                                                    border-bottom-right-radius: 4px;
                                                                    border-bottom-left-radius: 4px;
                                                                    selected: root.input-selected == 0;
                                                                    lit: root.input-lit[0];
                                                                    clicked => { root.input-key-selected(0); }
                                                                }
                                                                Rectangle { width: 34px; height: 34px; }
                                                            }
                                                            HorizontalLayout {
                                                                spacing: 2px;
                                                                GbaKey {
                                                                    width: 34px;
                                                                    height: 34px;
                                                                    glyph: Glyphs.chevron-left;
                                                                    text-size: 16px;
                                                                    border-top-left-radius: 10px;
                                                                    border-top-right-radius: 4px;
                                                                    border-bottom-right-radius: 4px;
                                                                    border-bottom-left-radius: 10px;
                                                                    selected: root.input-selected == 2;
                                                                    lit: root.input-lit[2];
                                                                    clicked => { root.input-key-selected(2); }
                                                                }
                                                                // hub (inert)
                                                                Rectangle {
                                                                    width: 34px;
                                                                    height: 34px;
                                                                    background: Theme.light ? #fbf9f3 : #323434;
                                                                    border-radius: 4px;
                                                                    border-width: 1px;
                                                                    border-color: Theme.input-border;
                                                                }
                                                                GbaKey {
                                                                    width: 34px;
                                                                    height: 34px;
                                                                    glyph: Glyphs.chevron-right;
                                                                    text-size: 16px;
                                                                    border-top-left-radius: 4px;
                                                                    border-top-right-radius: 10px;
                                                                    border-bottom-right-radius: 10px;
                                                                    border-bottom-left-radius: 4px;
                                                                    selected: root.input-selected == 3;
                                                                    lit: root.input-lit[3];
                                                                    clicked => { root.input-key-selected(3); }
                                                                }
                                                            }
                                                            HorizontalLayout {
                                                                spacing: 2px;
                                                                Rectangle { width: 34px; height: 34px; }
                                                                GbaKey {
                                                                    width: 34px;
                                                                    height: 34px;
                                                                    glyph: Glyphs.chevron-down;
                                                                    text-size: 16px;
                                                                    border-top-left-radius: 4px;
                                                                    border-top-right-radius: 4px;
                                                                    border-bottom-right-radius: 10px;
                                                                    border-bottom-left-radius: 10px;
                                                                    selected: root.input-selected == 1;
                                                                    lit: root.input-lit[1];
                                                                    clicked => { root.input-key-selected(1); }
                                                                }
                                                                Rectangle { width: 34px; height: 34px; }
                                                            }
                                                        }

                                                        // Start/Select: small pills, Start on
                                                        // top and nudged right — flattening
                                                        // the real console's slanted pair.
                                                        // Face labels stay literal like the
                                                        // silkscreen (the localized name
                                                        // shows on the bezel caption).
                                                        VerticalLayout {
                                                            spacing: 5px;
                                                            alignment: start;
                                                            HorizontalLayout {
                                                                alignment: start;
                                                                Rectangle { width: 12px; }
                                                                GbaKey {
                                                                    width: 64px;
                                                                    height: 20px;
                                                                    border-radius: 10px;
                                                                    label: "START";
                                                                    text-size: 11px;
                                                                    selected: root.input-selected == 8;
                                                                    lit: root.input-lit[8];
                                                                    clicked => { root.input-key-selected(8); }
                                                                }
                                                            }
                                                            HorizontalLayout {
                                                                alignment: start;
                                                                GbaKey {
                                                                    width: 64px;
                                                                    height: 20px;
                                                                    border-radius: 10px;
                                                                    label: "SELECT";
                                                                    text-size: 11px;
                                                                    selected: root.input-selected == 9;
                                                                    lit: root.input-lit[9];
                                                                    clicked => { root.input-key-selected(9); }
                                                                }
                                                            }
                                                        }
                                                    }
                                                }

                                                Rectangle { horizontal-stretch: 1; }

                                                // The glass bezel + LCD: shows the
                                                // selected key's binding chips and the
                                                // add/capture flow.
                                                VerticalLayout {
                                                    alignment: center;
                                                    Rectangle {
                                                        background: Theme.light ? #26262e : #060707;
                                                        border-radius: 14px;
                                                        border-width: 1px;
                                                        border-color: #00000080;

                                                        VerticalLayout {
                                                            padding-top: 12px;
                                                            padding-right: 14px;
                                                            padding-bottom: 4px;
                                                            padding-left: 14px;
                                                            spacing: 4px;

                                                            // the LCD
                                                            Rectangle {
                                                                width: 252px;
                                                                height: 168px;
                                                                background: Theme.light ? #f7f3e6 : #0a0b0c;
                                                                border-radius: 4px;
                                                                border-width: 1px;
                                                                border-color: #00000059;
                                                                clip: true;

                                                                if root.input-selected == -1 : Text {
                                                                    width: 100%;
                                                                    height: 100%;
                                                                    text: I18n.input-select-hint;
                                                                    wrap: word-wrap;
                                                                    font-size: 13px;
                                                                    color: Theme.text-muted;
                                                                    horizontal-alignment: center;
                                                                    vertical-alignment: center;
                                                                }
                                                                if root.input-selected >= 0 : VerticalLayout {
                                                                    padding: 8px;
                                                                    alignment: center;
                                                                    spacing: 10px;

                                                                    // Binding chips, stacked (the
                                                                    // realistic 3-4 per key fit).
                                                                    VerticalLayout {
                                                                        spacing: 6px;
                                                                        for chip[i] in root.input-chips : HorizontalLayout {
                                                                            alignment: center;
                                                                            Rectangle {
                                                                                height: 24px;
                                                                                border-radius: 12px;
                                                                                background: chip.lit ? #4caf5040 : Theme.btn-plate;
                                                                                border-width: 1px;
                                                                                border-color: chip.lit ? Theme.primary : Theme.input-border;
                                                                                HorizontalLayout {
                                                                                    padding-left: 10px;
                                                                                    padding-right: 5px;
                                                                                    spacing: 6px;
                                                                                    LIcon {
                                                                                        text: chip.glyph;
                                                                                        font-size: 12px;
                                                                                        color: Theme.text-muted;
                                                                                    }
                                                                                    Text {
                                                                                        text: chip.label;
                                                                                        font-size: 12px;
                                                                                        color: Theme.text;
                                                                                        vertical-alignment: center;
                                                                                        overflow: elide;
                                                                                        max-width: 150px;
                                                                                    }
                                                                                    Rectangle {
                                                                                        width: 18px;
                                                                                        height: 18px;
                                                                                        y: 3px;
                                                                                        border-radius: 9px;
                                                                                        background: cxta.has-hover ? Theme.hover : transparent;
                                                                                        cxta := TouchArea {
                                                                                            clicked => { root.input-binding-remove(i); }
                                                                                        }
                                                                                        LIcon {
                                                                                            width: 100%;
                                                                                            height: 100%;
                                                                                            text: Glyphs.x;
                                                                                            font-size: 10px;
                                                                                            color: cxta.has-hover ? Theme.danger : Theme.text-muted;
                                                                                        }
                                                                                    }
                                                                                }
                                                                            }
                                                                        }
                                                                    }

                                                                    // Capture swaps the Add button for
                                                                    // the prompt + a cancel chip.
                                                                    if root.input-capturing : HorizontalLayout {
                                                                        alignment: center;
                                                                        spacing: 8px;
                                                                        Text {
                                                                            text: I18n.input-press-key;
                                                                            font-size: 13px;
                                                                            color: Theme.primary;
                                                                            vertical-alignment: center;
                                                                        }
                                                                        NeutralButton {
                                                                            glyph: Glyphs.x;
                                                                            clicked => { root.input-capture-cancel(); }
                                                                        }
                                                                    }
                                                                    if !root.input-capturing : HorizontalLayout {
                                                                        alignment: center;
                                                                        TechPlate {
                                                                            r: 10px;
                                                                            background: adta.has-hover ? Theme.hover : Theme.btn-plate;
                                                                            border-width: 1px;
                                                                            border-color: Theme.input-border;
                                                                            adta := TouchArea {
                                                                                clicked => { root.input-capture-start(); }
                                                                            }
                                                                            HorizontalLayout {
                                                                                padding-top: 5px;
                                                                                padding-bottom: 5px;
                                                                                padding-left: 12px;
                                                                                padding-right: 12px;
                                                                                spacing: 6px;
                                                                                LIcon {
                                                                                    text: Glyphs.plus;
                                                                                    font-size: 12px;
                                                                                }
                                                                                Text {
                                                                                    text: I18n.input-add;
                                                                                    font-size: 12px;
                                                                                    color: Theme.text;
                                                                                    vertical-alignment: center;
                                                                                }
                                                                            }
                                                                        }
                                                                    }
                                                                }
                                                            }

                                                            // Silkscreen caption: the selected
                                                            // key's name in the UI language.
                                                            // Fixed-height slot so selecting
                                                            // never reflows the bezel.
                                                            Text {
                                                                height: 16px;
                                                                text: root.input-selected-label;
                                                                font-size: 11px;
                                                                color: #d1d1dbe6;
                                                                horizontal-alignment: center;
                                                            }
                                                        }
                                                    }
                                                }

                                                Rectangle { horizontal-stretch: 1; }

                                                // A/B: round keys on a diagonal, A
                                                // raised on the right.
                                                VerticalLayout {
                                                    alignment: center;
                                                    HorizontalLayout {
                                                        spacing: 8px;
                                                        VerticalLayout {
                                                            Rectangle { height: 20px; }
                                                            GbaKey {
                                                                width: 46px;
                                                                height: 46px;
                                                                border-radius: 23px;
                                                                label: "B";
                                                                text-size: 18px;
                                                                selected: root.input-selected == 5;
                                                                lit: root.input-lit[5];
                                                                clicked => { root.input-key-selected(5); }
                                                            }
                                                        }
                                                        VerticalLayout {
                                                            GbaKey {
                                                                width: 46px;
                                                                height: 46px;
                                                                border-radius: 23px;
                                                                label: "A";
                                                                text-size: 18px;
                                                                selected: root.input-selected == 4;
                                                                lit: root.input-lit[4];
                                                                clicked => { root.input-key-selected(4); }
                                                            }
                                                            Rectangle { height: 20px; }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }

                                    // Fast-forward isn't a console key; it sits
                                    // under the shell as a pill sharing the key
                                    // chrome, with Reset on the opposite edge.
                                    HorizontalLayout {
                                        width: 560px;
                                        GbaKey {
                                            height: 28px;
                                            border-radius: 14px;
                                            pad-h: 12px;
                                            glyph: Glyphs.fast-forward;
                                            label: I18n.input-speed-up;
                                            selected: root.input-selected == 10;
                                            lit: root.input-lit[10];
                                            clicked => { root.input-key-selected(10); }
                                        }
                                        Rectangle { horizontal-stretch: 1; }
                                        TechPlate {
                                            r: 10px;
                                            background: rsta.has-hover ? Theme.hover : Theme.btn-plate;
                                            border-width: 1px;
                                            border-color: Theme.input-border;
                                            rsta := TouchArea {
                                                clicked => { root.input-reset(); }
                                            }
                                            HorizontalLayout {
                                                padding-top: 6px;
                                                padding-bottom: 6px;
                                                padding-left: 12px;
                                                padding-right: 12px;
                                                spacing: 6px;
                                                LIcon {
                                                    text: Glyphs.refresh-cw;
                                                    font-size: 13px;
                                                }
                                                Text {
                                                    text: I18n.input-reset;
                                                    font-size: 13px;
                                                    color: Theme.text;
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // ---- session view: replaces the whole body, no top bar ----
    if root.in-session : Rectangle {
        width: 100%;
        height: 100%;
        background: black;

        // BNLC bezel art (cover-fit, crops as needed) behind the
        // framebuffer + every floating control; black when hidden or
        // unavailable.
        if root.session-bg-has && !root.settings-hide-border : Image {
            width: 100%;
            height: 100%;
            source: root.session-bg;
            image-fit: cover;
        }

        fs := FocusScope {
            width: 100%;
            height: 100%;
            init => { self.focus(); }
            key-pressed(event) => {
                root.key-event(event.text, true);
                accept
            }
            key-released(event) => {
                root.key-event(event.text, false);
                accept
            }

            // Integer scaling with a drop shadow, like the wgpu
            // framebuffer view; fractional scaling = smooth aspect-fit,
            // no shadow, matching tango's config.fractional_scaling.
            property <int> scale: max(1, Math.floor(min(
                self.width / 240px,
                self.height / 160px)));
            property <float> fscale: min(
                self.width / 240px,
                self.height / 160px);
            Rectangle {
                width: root.fractional ? 240px * fs.fscale : 240px * fs.scale;
                height: root.fractional ? 160px * fs.fscale : 160px * fs.scale;
                drop-shadow-blur: root.fractional ? 0px : 24px;
                drop-shadow-color: root.fractional ? transparent : #000000cc;
                Image {
                    width: 100%;
                    height: 100%;
                    source: root.frame;
                    image-fit: fill;
                    image-rendering: pixelated;
                }
            }
        }

        // Pointer-idle tracker: sits beneath every floating control, so
        // their own hits still land while any motion over the view
        // refreshes the idle clock.
        TouchArea {
            width: 100%;
            height: 100%;
            moved => { root.session-pointer-moved(); }
            clicked => { root.session-pointer-moved(); }
        }

        // Replay transport (floating_controls stand-in): play/pause,
        // tick readout, scrubber with prefetch fill + round marks,
        // speed picker.
        if root.session-kind == 1 : TechPlate {
            r: 10px;
            x: (parent.width - self.width) / 2;
            visible: root.session-controls-visible;
            y: parent.height - self.height - 12px;
            width: min(parent.width - 24px, 680px);
            height: 56px;
            background: #000000b3;
            border-width: 1px;
            border-color: #ffffff1a;

            HorizontalLayout {
                padding: 8px;
                spacing: 12px;

                // circular play/pause
                Rectangle {
                    width: 40px;
                    height: 40px;
                    border-radius: 20px;
                    background: pta.has-hover ? #4caf50 : #ffffff14;
                    pta := TouchArea {
                        clicked => { root.toggle-pause(); }
                    }
                    LIcon {
                        width: 100%;
                        height: 100%;
                        text: root.replay-paused ? Glyphs.play : Glyphs.pause;
                        font-size: 15px;
                        color: white;
                    }
                }

                // scrubber
                scrub := Rectangle {
                    height: 40px;
                    horizontal-stretch: 1;
                    property <bool> dragging: sta.pressed;
                    property <float> drag-frac: max(0.0, min(1.0, sta.mouse-x / self.width));
                    property <float> shown: self.dragging ? self.drag-frac : root.replay-scrub-pos;

                    Rectangle {
                        y: parent.height / 2 - 3px;
                        height: 6px;
                        width: 100%;
                        border-radius: 3px;
                        background: #ffffff14;
                    }
                    Rectangle {
                        y: parent.height / 2 - 3px;
                        height: 6px;
                        width: parent.width * min(1.0, root.replay-prefetch);
                        border-radius: 3px;
                        background: #4caf5040;
                    }
                    Rectangle {
                        y: parent.height / 2 - 3px;
                        height: 6px;
                        width: parent.width * scrub.shown;
                        border-radius: 3px;
                        background: #4caf50;
                    }
                    for mark in root.replay-marks : Rectangle {
                        x: scrub.width * mark - 1px;
                        y: scrub.height / 2 - 6px;
                        width: 2px;
                        height: 12px;
                        background: #ffffff66;
                    }
                    Rectangle {
                        x: scrub.width * scrub.shown - 7px;
                        y: parent.height / 2 - 7px;
                        width: 14px;
                        height: 14px;
                        border-radius: 7px;
                        background: white;
                        border-width: 1px;
                        border-color: #00000040;
                    }
                    // Hover thumbnail: the nearest keyframe to the
                    // hovered position, floated above the bar.
                    if sta.has-hover && !sta.pressed && root.replay-hover-has-thumb : Rectangle {
                        x: max(0px, min(parent.width - self.width,
                            sta.mouse-x - self.width / 2));
                        y: -self.height - 10px;
                        width: 168px;
                        height: 112px;
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: #ffffff33;
                        clip: true;
                        Image {
                            width: 100%;
                            height: 100%;
                            source: root.replay-hover-thumb;
                            image-fit: fill;
                            image-rendering: pixelated;
                        }
                    }
                    sta := TouchArea {
                        moved => {
                            if (!self.pressed) {
                                root.scrub-hover(max(0.0, min(1.0, self.mouse-x / scrub.width)));
                            }
                            if (self.pressed) {
                                root.scrub-moved(max(0.0, min(1.0, self.mouse-x / scrub.width)));
                            }
                        }
                        pointer-event(event) => {
                            if (event.kind == PointerEventKind.down) {
                                root.scrub-started();
                                root.scrub-moved(max(0.0, min(1.0, self.mouse-x / scrub.width)));
                            } else if (event.kind == PointerEventKind.up) {
                                root.scrub-committed(max(0.0, min(1.0, self.mouse-x / scrub.width)));
                            }
                        }
                    }
                }

                Text {
                    text: root.replay-progress;
                    font-size: 14px;
                    color: #4caf50;
                    vertical-alignment: center;
                }

                Picker {
                    width: 78px;
                    model: ["0.5×", "1×", "2×", "4×"];
                    placeholder: "1×";
                    current <=> root.replay-speed;
                    selected(i) => { root.speed-selected(i); }
                }
            }
        }

        // PvP telemetry footer (session/view/telemetry.rs, condensed):
        // player tag + tps + ping + skew/lead, and the live frame-delay
        // slider (purely local presentation lag).
        if root.session-kind == 2 : TechPlate {
            r: 10px;
            x: (parent.width - self.width) / 2;
            visible: root.session-controls-visible;
            y: parent.height - self.height - 12px;
            width: min(parent.width - 24px, 680px);
            height: 48px;
            background: #000000b3;
            border-width: 1px;
            border-color: #ffffff1a;

            HorizontalLayout {
                padding: 8px;
                padding-left: 14px;
                padding-right: 14px;
                spacing: 12px;
                Text {
                    text: root.pvp-stats;
                    font-size: 13px;
                    color: #4caf50;
                    vertical-alignment: center;
                    overflow: elide;
                    horizontal-stretch: 1;
                }
                Text {
                    text: I18n.lobby-frame-delay;
                    font-size: 11px;
                    color: Theme.text-muted;
                    vertical-alignment: center;
                }
                VerticalLayout {
                    alignment: center;
                    ChunkySlider {
                        width: 140px;
                        value <=> root.pvp-frame-delay;
                        changed(v) => { root.pvp-frame-delay-changed(v); }
                    }
                }
                Text {
                    width: 18px;
                    text: root.pvp-frame-delay-label;
                    font-size: 13px;
                    color: Theme.text;
                    vertical-alignment: center;
                }
            }
        }

        // Quiet corner settings gear — the in-session settings modal
        // (session/view's gear): the audio/video quick settings over a
        // dimmed backdrop while the emulator keeps running.
        TechPlate {
            r: 10px;
            x: parent.width - self.width - 52px;
            y: 12px;
            visible: root.session-controls-visible;
            background: gta.has-hover ? #4caf5033 : #00000080;
            border-width: 1px;
            border-color: #ffffff1a;
            gta := TouchArea {
                clicked => { root.session-settings-open = !root.session-settings-open; }
            }
            HorizontalLayout {
                padding-top: 6px;
                padding-bottom: 6px;
                padding-left: 8px;
                padding-right: 8px;
                LIcon {
                    text: Glyphs.settings;
                    font-size: 13px;
                    color: gta.has-hover ? #4caf50 : Theme.text-muted;
                }
            }
        }

        if root.session-settings-open : Rectangle {
            width: 100%;
            height: 100%;
            background: #000000aa;
            // Clicking the backdrop closes; the panel swallows its own.
            TouchArea {
                clicked => { root.session-settings-open = false; }
            }
            VerticalLayout {
                alignment: center;
                HorizontalLayout {
                    alignment: center;
                    Panel {
                        width: 420px;
                        TouchArea {}
                        VerticalLayout {
                            padding: 20px;
                            spacing: 14px;
                            Labeled {
                                label: I18n.settings-volume;
                                HorizontalLayout {
                                    spacing: 8px;
                                    ChunkySlider {
                                        value <=> root.settings-volume;
                                        changed(v) => { root.volume-changed(v); }
                                    }
                                    Text {
                                        text: root.settings-volume-label;
                                        font-size: 13px;
                                        color: Theme.text;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                            Labeled {
                                label: I18n.settings-video-filter;
                                Picker {
                                    width: 240px;
                                    model: ["—", "hq2x", "hq3x", "hq4x", "MMPX", "LCD"];
                                    placeholder: "—";
                                    current <=> root.settings-video-filter;
                                    selected(i) => { root.video-filter-changed(i); }
                                }
                            }
                            ChunkyCheckbox {
                                label: I18n.settings-fractional;
                                checked <=> root.fractional;
                                toggled(b) => { root.fractional-changed(b); }
                            }
                            ChunkyCheckbox {
                                label: I18n.settings-mute-bgm;
                                checked <=> root.settings-mute-bgm;
                                toggled(b) => { root.mute-bgm-changed(b); }
                            }
                        }
                    }
                }
            }
        }

        // Quiet corner close chip (tear-down), top-right.
        TechPlate {
            r: 10px;
            x: parent.width - self.width - 12px;
            y: 12px;
            visible: root.session-controls-visible;
            background: xta.has-hover ? #ff525233 : #00000080;
            border-width: 1px;
            border-color: xta.has-hover ? #ff5252aa : #ffffff1a;
            xta := TouchArea {
                clicked => { root.stop-clicked(); }
            }
            HorizontalLayout {
                padding-top: 6px;
                padding-bottom: 6px;
                padding-left: 8px;
                padding-right: 8px;
                LIcon {
                    text: Glyphs.x;
                    font-size: 13px;
                    color: xta.has-hover ? #ff5252 : Theme.text-muted;
                }
            }
        }

        // Setup drawers (session/view's edge panels): my setup from the
        // left, the opponent's from the right — each is the shared
        // SaveViewBody over the session (Rust re-points the SaveView
        // global as the handles toggle).
        if root.session-kind == 2 && root.session-drawer != 0 : Rectangle {
            x: root.session-drawer == 1 ? 0 : parent.width - self.width;
            width: min(560px, parent.width * 0.62);
            height: 100%;
            background: Theme.bg;
            VerticalLayout {
                padding: 12px;
                SaveViewBody {
                    vertical-stretch: 1;
                }
            }
        }
        if root.session-kind == 2 : TechPlate {
            r: 10px;
            x: root.session-drawer == 1
                ? min(560px, parent.width * 0.62) + 8px
                : 12px;
            y: (parent.height - self.height) / 2;
            background: dlta.has-hover ? #4caf5033 : #00000080;
            border-width: 1px;
            border-color: #ffffff1a;
            dlta := TouchArea {
                clicked => {
                    root.session-drawer = root.session-drawer == 1 ? 0 : 1;
                    root.session-drawer-changed(root.session-drawer);
                }
            }
            HorizontalLayout {
                padding: 8px;
                LIcon {
                    text: root.session-drawer == 1 ? Glyphs.chevron-left : Glyphs.chevron-right;
                    font-size: 15px;
                    color: Theme.text;
                }
            }
        }
        if root.session-kind == 2 && !root.pvp-opponent-blind : TechPlate {
            r: 10px;
            x: root.session-drawer == 2
                ? parent.width - min(560px, parent.width * 0.62) - self.width - 8px
                : parent.width - self.width - 12px;
            y: (parent.height - self.height) / 2;
            background: drta.has-hover ? #2984de33 : #00000080;
            border-width: 1px;
            border-color: #ffffff1a;
            drta := TouchArea {
                clicked => {
                    root.session-drawer = root.session-drawer == 2 ? 0 : 2;
                    root.session-drawer-changed(root.session-drawer);
                }
            }
            HorizontalLayout {
                padding: 8px;
                LIcon {
                    text: root.session-drawer == 2 ? Glyphs.chevron-right : Glyphs.chevron-left;
                    font-size: 15px;
                    color: Theme.text;
                }
            }
        }

        // Mid-match reconnect overlay (session/view's reconnect modal):
        // the emulator is paused while the transport rebuilds; the bar
        // depletes toward the give-up deadline.
        if root.pvp-reconnecting : Rectangle {
            width: 100%;
            height: 100%;
            background: #000000aa;
            VerticalLayout {
                alignment: center;
                HorizontalLayout {
                    alignment: center;
                    Panel {
                        width: 380px;
                        VerticalLayout {
                            padding: 24px;
                            spacing: 12px;
                            Text {
                                text: I18n.pvp-reconnecting;
                                font-size: 17px;
                                color: Theme.text;
                            }
                            Text {
                                text: I18n.pvp-reconnecting-detail;
                                font-size: 13px;
                                color: Theme.text-muted;
                            }
                            Rectangle {
                                height: 6px;
                                border-radius: 3px;
                                background: #ffffff14;
                                Rectangle {
                                    x: 0;
                                    height: 100%;
                                    width: parent.width * max(0.0, min(1.0, root.pvp-reconnect-progress));
                                    border-radius: 3px;
                                    background: #4caf50;
                                }
                            }
                            HorizontalLayout {
                                alignment: end;
                                DangerTextButton {
                                    label: I18n.pvp-disconnect;
                                    clicked => { root.exit-confirmed(); }
                                }
                            }
                        }
                    }
                }
            }
        }

        // Disconnect confirm (session/view's disconnect modal): gates
        // tearing down a live match from the X chip / Escape.
        if root.session-confirm-exit : Rectangle {
            width: 100%;
            height: 100%;
            background: #000000aa;
            // Swallow clicks so the session beneath stays inert.
            TouchArea {}
            VerticalLayout {
                alignment: center;
                HorizontalLayout {
                    alignment: center;
                    Panel {
                        width: 380px;
                        VerticalLayout {
                            padding: 24px;
                            spacing: 12px;
                            Text {
                                text: I18n.pvp-disconnect-prompt;
                                font-size: 17px;
                                color: Theme.text;
                            }
                            Text {
                                text: I18n.pvp-disconnect-detail;
                                font-size: 13px;
                                color: Theme.text-muted;
                                wrap: word-wrap;
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                alignment: end;
                                NeutralTextButton {
                                    label: I18n.save-action-cancel;
                                    clicked => { root.session-confirm-exit = false; }
                                }
                                DangerTextButton {
                                    label: I18n.pvp-disconnect;
                                    clicked => { root.exit-confirmed(); }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
    // ---- welcome / first-run overlay (tabs/welcome.rs) ----
    // Shown until a nickname is set: language pick, ROMs step (open
    // folder / rescan / detected count), nickname step gated on >= 1
    // ROM. Continue writes the nickname and never shows this again.
    if root.welcome-visible : Rectangle {
        width: 100%;
        height: 100%;
        background: Theme.bg;
        VerticalLayout {
            alignment: center;
            HorizontalLayout {
                alignment: center;
                Panel {
                    width: 560px;
                    VerticalLayout {
                        padding: 28px;
                        spacing: 12px;
                        Text {
                            text: I18n.welcome-title;
                            font-size: 22px;
                            color: Theme.text;
                        }
                        Text {
                            text: I18n.welcome-subtitle;
                            font-size: 13px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        Labeled {
                            label: I18n.settings-language;
                            Picker {
                                width: 240px;
                                model: root.languages;
                                placeholder: "—";
                                current <=> root.settings-language;
                                selected(i) => { root.language-selected(i); }
                            }
                        }
                        Rectangle { height: 6px; }
                        Text {
                            text: I18n.welcome-step-roms;
                            font-size: 15px;
                            color: Theme.text;
                        }
                        Text {
                            text: I18n.welcome-step-roms-description;
                            font-size: 12px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        Text {
                            text: root.welcome-roms-path;
                            font-size: 12px;
                            color: Theme.text;
                            overflow: elide;
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            alignment: start;
                            NeutralTextButton {
                                label: I18n.welcome-open-folder;
                                clicked => { root.welcome-open-roms(); }
                            }
                            NeutralTextButton {
                                label: I18n.welcome-rescan;
                                clicked => { root.welcome-rescan(); }
                            }
                            VerticalLayout {
                                alignment: center;
                                Text {
                                    text: root.welcome-roms-detected;
                                    font-size: 12px;
                                    color: root.welcome-has-roms ? Theme.text : Theme.text-muted;
                                }
                            }
                        }
                        Rectangle { height: 6px; }
                        Text {
                            text: I18n.welcome-step-nickname;
                            font-size: 15px;
                            color: Theme.text;
                        }
                        Text {
                            text: I18n.welcome-step-nickname-description;
                            font-size: 12px;
                            color: Theme.text-muted;
                            wrap: word-wrap;
                        }
                        ChunkyInput {
                            width: 240px;
                            text <=> root.welcome-nickname;
                            accepted(t) => { root.welcome-continue(); }
                        }
                        HorizontalLayout {
                            spacing: 10px;
                            if !root.welcome-has-roms : VerticalLayout {
                                alignment: center;
                                Text {
                                    text: I18n.welcome-roms-needed;
                                    font-size: 12px;
                                    color: Theme.text-muted;
                                }
                            }
                            Rectangle { horizontal-stretch: 1; }
                            PrimaryButton {
                                label: I18n.welcome-continue;
                                enabled: root.welcome-has-roms && root.welcome-nickname != "";
                                clicked => { root.welcome-continue(); }
                            }
                        }
                    }
                }
            }
        }
    }
}
