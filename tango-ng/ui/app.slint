// tango-ng shell, styled to match the existing tango (iced) UI:
// top tab bar with pill tabs + accent scanline, panes with hairline
// green borders, the asymmetric "tech" corner radius on plates, gold
// selection with navy ink, green gradient CTAs, Noto Sans 13px body,
// lucide iconography. Values come from tango/src/{theme,style}.rs and
// widgets.rs (TANGO_GREEN #4caf50, SELECT_YELLOW #ffd23d, dark base
// #0e1011, type scale 22/18/15/13/11, PANE_PADDING 12, PANE_GAP 8,
// BAR_CONTROL_HEIGHT 40, tech_radius(r) = r on TL/BR + min(r/4, 3) on
// TR/BL).

import "./fonts/lucide.ttf";
import "../../tango/fonts/NotoSans-Regular.ttf";
import { ListView } from "std-widgets.slint";

// Light values follow tango's "warm cream + slate" light palette
// (#f3eedc bg / #142234 text); dark is the primary identity.
export global Theme {
    in-out property <bool> light: false;
    out property <color> bg: light ? #f3eedc : #0e1011;
    out property <color> text: light ? #142234 : #eceeed;
    out property <color> text-muted: light ? #6b7787 : #8f9793;
    out property <color> primary: #4caf50;
    out property <color> gold: #ffd23d;
    out property <color> ink: #142234;
    out property <color> danger: light ? #d13a3a : #ff5252;
    out property <color> plate: light ? #eae3cf : #17191b;
    out property <color> plate-input: light ? #e6dfc9 : #14171a;
    out property <color> plate-popup: light ? #efe9d6 : #131517;
    out property <color> panel-bg: light ? #f0ebd8 : #191c1e;
    out property <color> hairline: #4caf5059;
    out property <color> hover: light ? #00000010 : #ffffff0d;
    out property <color> row-alt: light ? #00000008 : #ffffff05;
    out property <color> disabled-text: light ? #9aa3ae : #5a6274;
    out property <color> input-border: light ? #00000022 : #ffffff1a;
    out property <color> btn-plate: light ? #00000008 : #ffffff0a;
}

// Lucide glyphs (codepoints from lucide-icons 1.16, the version tango pins).
export global Glyphs {
    out property <string> gamepad: "\u{e0de}";
    out property <string> film: "\u{e0d0}";
    out property <string> puzzle: "\u{e29c}";
    out property <string> settings: "\u{e154}";
    out property <string> swords: "\u{e2b4}";
    out property <string> play: "\u{e13c}";
    out property <string> file-plus: "\u{e0c9}";
    out property <string> ellipsis-v: "\u{e0b7}";
    out property <string> info: "\u{e0f9}";
    out property <string> chevron-down: "\u{e06d}";
    out property <string> sliders: "\u{e29a}";
    out property <string> monitor: "\u{e11d}";
    out property <string> volume: "\u{e1ab}";
    out property <string> gamepad2: "\u{e0df}";
    out property <string> globe: "\u{e0e8}";
    out property <string> x: "\u{e1b2}";
    out property <string> pause: "\u{e12e}";
}

component LIcon inherits Text {
    font-family: "lucide";
    color: Theme.text;
    vertical-alignment: center;
    horizontal-alignment: center;
}

// The signature asymmetric corner: top-left/bottom-right = r,
// top-right/bottom-left = min(r * 0.25, 3px).
component TechPlate inherits Rectangle {
    in property <length> r: 10px;
    border-top-left-radius: r;
    border-bottom-right-radius: r;
    border-top-right-radius: min(r * 0.25, 3px);
    border-bottom-left-radius: min(r * 0.25, 3px);
}

// Minimal tinted plate with hairline accent border — tab regions,
// list containers. Pair with 12px padding inside.
component Pane inherits Rectangle {
    background: Theme.plate;
    border-radius: 4px;
    border-width: 1px;
    border-color: Theme.hairline;
}

// Framed PET card — empty states, modals.
component Panel inherits TechPlate {
    r: 14px;
    background: Theme.panel-bg;
    border-width: 1.5px;
    border-color: #4caf5080;
    drop-shadow-blur: 24px;
    drop-shadow-color: Theme.light ? #00000040 : #000000aa;
    drop-shadow-offset-y: 6px;
}

component PillTab inherits TechPlate {
    in property <string> glyph;
    in property <string> label;
    in property <bool> active;
    callback clicked();

    r: 10px;
    background: root.active
        ? @linear-gradient(180deg, #58bd5c 0%, #3e9a42 100%)
        : (ta.has-hover ? Theme.hover : transparent);
    drop-shadow-blur: root.active ? 12px : 0px;
    drop-shadow-color: root.active ? #4caf5066 : transparent;

    ta := TouchArea {
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-top: 8px;
        padding-bottom: 8px;
        padding-left: 18px;
        padding-right: 18px;
        spacing: root.label == "" ? 0 : 8px;
        LIcon {
            text: root.glyph;
            font-size: 15px;
            color: root.active ? white : Theme.text-muted;
        }
        if root.label != "" : Text {
            text: root.label;
            font-size: 15px;
            color: root.active ? white : Theme.text-muted;
            vertical-alignment: center;
        }
    }
}

component PrimaryButton inherits TechPlate {
    in property <string> glyph;
    in property <string> label;
    in property <bool> enabled: true;
    in property <length> pad-v: 6px;
    in property <length> pad-h: 14px;
    in property <length> text-size: 13px;
    callback clicked();

    r: 10px;
    background: !root.enabled
        ? Theme.plate-input
        : (ta.has-hover
            ? @linear-gradient(180deg, #63cc67 0%, #46a84a 100%)
            : @linear-gradient(180deg, #58bd5c 0%, #3e9a42 100%));
    drop-shadow-blur: root.enabled ? 10px : 0px;
    drop-shadow-color: root.enabled ? #4caf5059 : transparent;

    ta := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-top: root.pad-v;
        padding-bottom: root.pad-v;
        padding-left: root.pad-h;
        padding-right: root.pad-h;
        spacing: root.glyph == "" || root.label == "" ? 0 : 8px;
        if root.glyph != "" : LIcon {
            text: root.glyph;
            font-size: root.text-size;
            color: root.enabled ? white : Theme.disabled-text;
        }
        if root.label != "" : Text {
            text: root.label;
            font-size: root.text-size;
            color: root.enabled ? white : Theme.disabled-text;
            vertical-alignment: center;
        }
    }
}

// Soft 3D plate, low-emphasis toolbar button (icon-only).
component NeutralButton inherits TechPlate {
    in property <string> glyph;
    in property <bool> enabled: true;
    callback clicked();

    r: 10px;
    background: !root.enabled ? Theme.plate-input : (ta.has-hover ? Theme.hover : Theme.btn-plate);
    border-width: 1px;
    border-color: Theme.input-border;

    ta := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-top: 6px;
        padding-bottom: 6px;
        padding-left: 14px;
        padding-right: 14px;
        LIcon {
            text: root.glyph;
            font-size: 13px;
            color: root.enabled ? Theme.text : Theme.disabled-text;
        }
    }
}

// Chunky pick_list stand-in: plate trigger + popup list with zebra
// rows and the gold selection register.
component Picker inherits TechPlate {
    in property <[string]> model;
    in property <string> placeholder;
    in property <bool> enabled: true;
    in-out property <int> current: -1;
    callback selected(int);

    r: 10px;
    height: 34px;
    background: !root.enabled ? Theme.plate-input : (ta.has-hover ? Theme.hover : Theme.btn-plate);
    border-width: 1px;
    border-color: !root.enabled ? transparent : Theme.input-border;

    ta := TouchArea {
        enabled: root.enabled && root.model.length > 0;
        clicked => { popup.show(); }
    }

    HorizontalLayout {
        padding-left: 14px;
        padding-right: 10px;
        spacing: 6px;
        Text {
            text: root.current >= 0 && root.current < root.model.length
                ? root.model[root.current]
                : root.placeholder;
            color: !root.enabled
                ? Theme.disabled-text
                : (root.current >= 0 ? Theme.text : Theme.text-muted);
            font-size: 13px;
            vertical-alignment: center;
            overflow: elide;
            horizontal-stretch: 1;
        }
        LIcon {
            text: Glyphs.chevron-down;
            font-size: 11px;
            color: root.enabled ? Theme.text-muted : Theme.disabled-text;
        }
    }

    popup := PopupWindow {
        x: 0;
        y: root.height + 2px;
        width: max(root.width, 180px);
        height: min(root.model.length * 34px + 10px, 340px);
        close-policy: close-on-click-outside;

        Rectangle {
            background: Theme.plate-popup;
            border-width: 1px;
            border-color: Theme.hairline;
            border-radius: 4px;

            ListView {
                x: 4px;
                y: 4px;
                width: parent.width - 8px;
                height: parent.height - 8px;
                for item[i] in root.model : Rectangle {
                    height: 34px;
                    border-radius: 4px;
                    background: i == root.current
                        ? @linear-gradient(180deg, #ffd23d 0%, #e6b520 100%)
                        : (ita.has-hover
                            ? Theme.hover
                            : (Math.mod(i, 2) == 0 ? transparent : Theme.row-alt));
                    ita := TouchArea {
                        clicked => {
                            root.current = i;
                            root.selected(i);
                            popup.close();
                        }
                    }
                    Text {
                        x: 10px;
                        width: parent.width - 20px;
                        height: parent.height;
                        text: item;
                        font-size: 13px;
                        color: i == root.current ? Theme.ink : Theme.text;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }
            }
        }
    }
}

// Chunky text input: plate + accent focus ring, accepts on Enter.
component ChunkyInput inherits TechPlate {
    in-out property <string> text <=> ti.text;
    in property <bool> enabled: true;
    callback accepted(string);
    callback edited(string);

    r: 10px;
    height: 34px;
    background: !root.enabled ? Theme.plate-input : Theme.btn-plate;
    border-width: 1px;
    border-color: ti.has-focus ? Theme.primary : Theme.input-border;

    ti := TextInput {
        x: 14px;
        width: parent.width - 28px;
        height: parent.height;
        vertical-alignment: center;
        color: root.enabled ? Theme.text : Theme.disabled-text;
        font-size: 13px;
        single-line: true;
        enabled: root.enabled;
        accepted => { root.accepted(self.text); }
        edited => { root.edited(self.text); }
    }
}

// Chunky slider: 6px rail + circular handle (widgets::chunky_slider).
component ChunkySlider inherits Rectangle {
    in-out property <float> value: 1.0; // 0..1
    callback changed(float);

    height: 24px;
    width: 220px;

    Rectangle {
        y: parent.height / 2 - 3px;
        height: 6px;
        width: 100%;
        border-radius: 3px;
        background: Theme.plate-input;
        border-width: 1px;
        border-color: Theme.input-border;
    }
    Rectangle {
        y: parent.height / 2 - 3px;
        height: 6px;
        width: parent.width * root.value;
        border-radius: 3px;
        background: Theme.primary;
    }
    Rectangle {
        x: parent.width * root.value - 8px;
        y: parent.height / 2 - 8px;
        width: 16px;
        height: 16px;
        border-radius: 8px;
        background: white;
        border-width: 1px;
        border-color: #00000040;
    }
    TouchArea {
        moved => {
            if (self.pressed) {
                root.value = max(0.0, min(1.0, self.mouse-x / root.width));
                root.changed(root.value);
            }
        }
        clicked => {
            root.value = max(0.0, min(1.0, self.mouse-x / root.width));
            root.changed(root.value);
        }
    }
}

// Chunky checkbox: rounded box, primary fill + check glyph when on.
component ChunkyCheckbox inherits HorizontalLayout {
    in property <string> label;
    in-out property <bool> checked;
    callback toggled(bool);

    spacing: 8px;
    Rectangle {
        width: 18px;
        height: 18px;
        border-radius: 5px;
        background: root.checked ? Theme.primary : Theme.btn-plate;
        border-width: 1px;
        border-color: root.checked ? Theme.primary : Theme.input-border;
        TouchArea {
            clicked => {
                root.checked = !root.checked;
                root.toggled(root.checked);
            }
        }
        if root.checked : LIcon {
            width: 100%;
            height: 100%;
            text: "\u{e06c}"; // check
            font-size: 12px;
            color: white;
        }
    }
    Text {
        text: root.label;
        font-size: 13px;
        color: Theme.text;
        vertical-alignment: center;
    }
}

// Caption-over-control form row (widgets::labeled), gap 4.
component Labeled inherits VerticalLayout {
    in property <string> label;
    spacing: 4px;
    Text {
        text: root.label;
        font-size: 11px;
        color: Theme.text-muted;
    }
    @children
}

// Centered empty-state text on a pane (widgets::pane_prompt).
component PanePrompt inherits Pane {
    in property <string> message;
    Text {
        width: 100%;
        height: 100%;
        text: root.message;
        color: Theme.text-muted;
        font-size: 13px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

// 3px accent gradient strip (widgets::hud_scanline).
component Scanline inherits Rectangle {
    height: 3px;
    background: @linear-gradient(90deg, #4caf5000 0%, #4caf50b3 30%, #4caf50b3 70%, #4caf5000 100%);
}

// One replay-list row's display strings.
export struct ReplayRow {
    line1: string,
    line2: string,
}

export component AppWindow inherits Window {
    title: "Tango";
    preferred-width: 960px;
    preferred-height: 720px;
    min-width: 960px;
    min-height: 720px;
    background: Theme.bg;
    default-font-family: "Noto Sans";
    default-font-size: 13px;
    icon: @image-url("../../tango/src/icon.png");

    in property <[string]> games: [];
    in property <[string]> saves: [];
    in property <[string]> patches: [];
    in property <[string]> versions: [];
    in property <[ReplayRow]> replays: [];
    in property <[string]> replay-game-filters: [];
    in-out property <int> selected-replay-filter: 0;
    in property <string> replay-title: "";
    in property <[string]> replay-detail: [];
    in property <image> frame;
    in property <bool> in-session: false;
    in property <string> status: "";
    in property <[string]> languages: [];
    in property <string> app-version: "";
    in-out property <string> settings-nickname: "";
    in-out property <string> settings-data-path: "";
    in-out property <int> settings-language: -1;
    in-out property <int> settings-theme: 0;
    in-out property <float> settings-volume: 1.0;
    in property <string> settings-volume-label: "100%";
    in-out property <bool> fractional: false;
    // 0 = singleplayer, 1 = replay (shows the transport bar).
    in property <int> session-kind: 0;
    // Netplay: the typed link code / direct command, and the lifecycle
    // status line ("" while idle — the input shows instead).
    in-out property <string> link-code: "";
    in property <string> netplay-status: "";
    in property <bool> replay-paused: false;
    in property <string> replay-progress: "";
    in property <float> replay-scrub-pos: 0.0;
    in property <float> replay-prefetch: 0.0;
    in property <[float]> replay-marks: [];
    in-out property <int> replay-speed: 1;
    in-out property <int> active-tab: 0;
    in-out property <int> settings-section: 0;
    in-out property <int> selected-game: -1;
    in-out property <int> selected-save: -1;
    in-out property <int> selected-patch: 0;
    in-out property <int> selected-version: -1;
    in-out property <int> selected-replay: -1;

    callback game-selected(int);
    callback patch-selected(int);
    callback replay-selected(int);
    callback replay-filter-selected(int);
    callback replay-opponent-edited(string);
    callback play-clicked();
    callback fight-clicked();
    callback watch-clicked();
    callback toggle-pause();
    callback speed-selected(int);
    callback scrub-started();
    callback scrub-moved(float);
    callback scrub-committed(float);
    callback stop-clicked();
    callback key-event(string, bool);
    callback nickname-changed(string);
    callback language-selected(int);
    callback theme-selected(int);
    callback volume-changed(float);
    callback fractional-changed(bool);
    callback data-path-changed(string);

    if !root.in-session : VerticalLayout {
        width: 100%;
        height: 100%;

        // ---- top bar (hud_bar: gradient plate + shadow) ----
        Rectangle {
            background: Theme.light
                ? @linear-gradient(180deg, #fbf7ea 0%, #e8e2cd 100%)
                : @linear-gradient(180deg, #1b1e20 0%, #131516 100%);
            drop-shadow-blur: 10px;
            drop-shadow-color: Theme.light ? #00000030 : #00000080;
            drop-shadow-offset-y: 2px;
            HorizontalLayout {
                padding-top: 10px;
                padding-bottom: 10px;
                padding-left: 8px;
                padding-right: 8px;
                spacing: 8px;
                Rectangle {
                    width: 44px;
                    Image {
                        source: @image-url("../../tango/src/icon.png");
                        width: 28px;
                        height: 28px;
                        image-fit: contain;
                    }
                }
                PillTab {
                    glyph: Glyphs.gamepad;
                    label: "Play";
                    active: root.active-tab == 0;
                    clicked => { root.active-tab = 0; }
                }
                PillTab {
                    glyph: Glyphs.film;
                    label: "Replays";
                    active: root.active-tab == 1;
                    clicked => { root.active-tab = 1; }
                }
                Rectangle { horizontal-stretch: 1; }
                Text {
                    text: root.status;
                    font-size: 11px;
                    color: Theme.text-muted;
                    vertical-alignment: center;
                }
                PillTab {
                    glyph: Glyphs.puzzle;
                    label: "";
                    active: root.active-tab == 2;
                    clicked => { root.active-tab = 2; }
                }
                PillTab {
                    glyph: Glyphs.settings;
                    label: "";
                    active: root.active-tab == 3;
                    clicked => { root.active-tab = 3; }
                }
            }
        }
        Scanline { }

        // ---- body over the (approximated) backdrop wash ----
        Rectangle {
            background: Theme.light
                ? @linear-gradient(180deg, #f7f2e2 0%, #f3eedc 45%)
                : @linear-gradient(180deg, #12171a 0%, #0e1011 45%);
            vertical-stretch: 1;

            // Play
            if root.active-tab == 0 : VerticalLayout {
                width: 100%;
                height: 100%;

                VerticalLayout {
                    padding: 8px;
                    spacing: 8px;
                    vertical-stretch: 1;

                    // selector strip
                    Pane {
                        VerticalLayout {
                            padding: 12px;
                            spacing: 6px;
                            HorizontalLayout {
                                spacing: 8px;
                                Picker {
                                    model: root.games;
                                    placeholder: "No game selected";
                                    current <=> root.selected-game;
                                    horizontal-stretch: 3;
                                    selected(i) => {
                                        root.selected-save = -1;
                                        root.game-selected(i);
                                    }
                                }
                                Picker {
                                    model: root.patches;
                                    placeholder: "No patch";
                                    enabled: root.selected-game >= 0 && root.patches.length > 1;
                                    current <=> root.selected-patch;
                                    horizontal-stretch: 2;
                                    selected(i) => { root.patch-selected(i); }
                                }
                                Picker {
                                    model: root.versions;
                                    placeholder: "—";
                                    enabled: root.versions.length > 0;
                                    current <=> root.selected-version;
                                    width: 100px;
                                }
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                NeutralButton { glyph: Glyphs.file-plus; enabled: false; }
                                Picker {
                                    model: root.saves;
                                    placeholder: "No save selected";
                                    current <=> root.selected-save;
                                    horizontal-stretch: 1;
                                }
                                NeutralButton { glyph: Glyphs.ellipsis-v; enabled: false; }
                            }
                        }
                    }

                    // save body
                    if root.selected-save >= 0 : VerticalLayout {
                        spacing: 8px;
                        vertical-stretch: 1;
                        Pane {
                            HorizontalLayout {
                                padding: 12px;
                                spacing: 8px;
                                Text {
                                    text: root.selected-save >= 0 && root.selected-save < root.saves.length
                                        ? root.saves[root.selected-save]
                                        : "";
                                    font-size: 15px;
                                    color: Theme.text;
                                    vertical-alignment: center;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                }
                                PrimaryButton {
                                    glyph: Glyphs.play;
                                    label: "Play";
                                    pad-v: 4px;
                                    pad-h: 10px;
                                    clicked => { root.play-clicked(); }
                                }
                            }
                        }
                        PanePrompt {
                            message: "Save viewer coming soon";
                            vertical-stretch: 1;
                        }
                    }
                    if root.selected-save < 0 : Rectangle {
                        vertical-stretch: 1;
                        Panel {
                            width: min(520px, parent.width - 48px);
                            height: content.preferred-height;
                            content := VerticalLayout {
                                padding: 28px;
                                spacing: 8px;
                                alignment: center;
                                LIcon {
                                    text: Glyphs.info;
                                    font-size: 28px;
                                    color: Theme.primary;
                                }
                                Text {
                                    text: root.games.length == 0
                                        ? "No games found"
                                        : "Select a game and save";
                                    font-size: 18px;
                                    color: Theme.text;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: root.games.length == 0
                                        ? "Put ROMs in your Tango roms folder and restart."
                                        : "Pick a game and one of its saves above, then hit Play.";
                                    font-size: 11px;
                                    color: Theme.text-muted;
                                    horizontal-alignment: center;
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }
                }

                // bottom band, edge-to-edge
                Scanline { }
                Rectangle {
                    background: Theme.light
                        ? @linear-gradient(180deg, #fbf7ea 0%, #e8e2cd 100%)
                        : @linear-gradient(180deg, #1b1e20 0%, #131516 100%);
                    HorizontalLayout {
                        padding-top: 10px;
                        padding-bottom: 10px;
                        padding-left: 8px;
                        padding-right: 8px;
                        spacing: 10px;
                        // Link code / direct command entry; while a
                        // connection is in flight the same plate slot
                        // shows the lifecycle status instead (identical
                        // footprint, so the band never shifts).
                        if root.netplay-status == "" : ChunkyInput {
                            height: 40px;
                            horizontal-stretch: 1;
                            text <=> root.link-code;
                            accepted(t) => { root.fight-clicked(); }
                        }
                        if root.netplay-status != "" : TechPlate {
                            r: 10px;
                            height: 40px;
                            horizontal-stretch: 1;
                            background: Theme.plate-input;
                            border-width: 1px;
                            border-color: Theme.input-border;
                            Text {
                                x: 16px;
                                width: parent.width - 32px;
                                height: parent.height;
                                text: root.netplay-status;
                                font-size: 15px;
                                color: Theme.text;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                        }
                        PrimaryButton {
                            glyph: Glyphs.swords;
                            label: "Fight";
                            enabled: root.link-code != ""
                                && root.selected-game >= 0
                                && root.selected-save >= 0;
                            pad-v: 10px;
                            pad-h: 22px;
                            text-size: 15px;
                            height: 40px;
                            clicked => { root.fight-clicked(); }
                        }
                    }
                }
            }

            // Replays
            if root.active-tab == 1 : VerticalLayout {
                width: 100%;
                height: 100%;
                padding: 8px;
                spacing: 8px;
                Pane {
                    HorizontalLayout {
                        padding: 12px;
                        spacing: 8px;
                        Picker {
                            model: root.replay-game-filters;
                            placeholder: "All games";
                            current <=> root.selected-replay-filter;
                            width: 220px;
                            selected(i) => { root.replay-filter-selected(i); }
                        }
                        ChunkyInput {
                            width: 220px;
                            edited(t) => { root.replay-opponent-edited(t); }
                        }
                        Rectangle { horizontal-stretch: 1; }
                    }
                }
                HorizontalLayout {
                    spacing: 8px;
                    vertical-stretch: 1;

                    // replay list (fixed 360, like tango's)
                    Pane {
                        width: 360px;
                        if root.replays.length == 0 : Text {
                            width: 100%;
                            height: 100%;
                            text: "No replays found";
                            color: Theme.text-muted;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        if root.replays.length > 0 : ListView {
                            x: 4px;
                            y: 8px;
                            width: parent.width - 8px;
                            height: parent.height - 16px;
                            for entry[i] in root.replays : Rectangle {
                                height: 48px;
                                border-radius: 4px;
                                background: root.selected-replay == i
                                    ? @linear-gradient(180deg, #ffd23d 0%, #e6b520 100%)
                                    : (rta.has-hover
                                        ? Theme.hover
                                        : (Math.mod(i, 2) == 0 ? transparent : Theme.row-alt));
                                rta := TouchArea {
                                    clicked => {
                                        root.selected-replay = i;
                                        root.replay-selected(i);
                                    }
                                }
                                VerticalLayout {
                                    padding-left: 10px;
                                    padding-right: 10px;
                                    padding-top: 6px;
                                    padding-bottom: 6px;
                                    Text {
                                        text: entry.line1;
                                        font-size: 13px;
                                        color: root.selected-replay == i ? Theme.ink : Theme.text;
                                        overflow: elide;
                                    }
                                    Text {
                                        text: entry.line2;
                                        font-size: 11px;
                                        color: root.selected-replay == i ? Theme.ink : Theme.text-muted;
                                        overflow: elide;
                                    }
                                }
                            }
                        }
                    }

                    // detail
                    if root.selected-replay < 0 : PanePrompt {
                        horizontal-stretch: 1;
                        message: "Select a replay to view its details";
                    }
                    if root.selected-replay >= 0 : Pane {
                        horizontal-stretch: 1;
                        VerticalLayout {
                            padding: 12px;
                            spacing: 8px;
                            alignment: start;
                            HorizontalLayout {
                                spacing: 8px;
                                Text {
                                    text: root.replay-title;
                                    font-size: 18px;
                                    color: Theme.text;
                                    vertical-alignment: center;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                }
                                PrimaryButton {
                                    glyph: Glyphs.play;
                                    label: "Watch";
                                    pad-v: 4px;
                                    pad-h: 10px;
                                    clicked => { root.watch-clicked(); }
                                }
                            }
                            VerticalLayout {
                                spacing: 3px;
                                for line in root.replay-detail : Text {
                                    text: line;
                                    font-size: 13px;
                                    color: Theme.text-muted;
                                    overflow: elide;
                                }
                            }
                        }
                    }
                }
            }

            // Patches
            if root.active-tab == 2 : VerticalLayout {
                width: 100%;
                height: 100%;
                padding: 8px;
                PanePrompt {
                    message: "Patches coming soon";
                }
            }

            // Settings
            if root.active-tab == 3 : HorizontalLayout {
                width: 100%;
                height: 100%;
                padding: 8px;
                spacing: 8px;
                Pane {
                    width: 160px;
                    VerticalLayout {
                        padding: 8px;
                        spacing: 4px;
                        PillTab {
                            glyph: Glyphs.sliders;
                            label: "General";
                            active: root.settings-section == 0;
                            clicked => { root.settings-section = 0; }
                        }
                        PillTab {
                            glyph: Glyphs.monitor;
                            label: "Graphics";
                            active: root.settings-section == 1;
                            clicked => { root.settings-section = 1; }
                        }
                        PillTab {
                            glyph: Glyphs.volume;
                            label: "Audio";
                            active: root.settings-section == 2;
                            clicked => { root.settings-section = 2; }
                        }
                        PillTab {
                            glyph: Glyphs.gamepad2;
                            label: "Input";
                            active: root.settings-section == 3;
                            clicked => { root.settings-section = 3; }
                        }
                        PillTab {
                            glyph: Glyphs.globe;
                            label: "Netplay";
                            active: root.settings-section == 4;
                            clicked => { root.settings-section = 4; }
                        }
                        PillTab {
                            glyph: Glyphs.info;
                            label: "About";
                            active: root.settings-section == 5;
                            clicked => { root.settings-section = 5; }
                        }
                        Rectangle { vertical-stretch: 1; }
                    }
                }
                Pane {
                    horizontal-stretch: 1;
                    if root.settings-section == 0 : VerticalLayout {
                        padding: 12px;
                        spacing: 14px;
                        alignment: start;
                        Labeled {
                            label: "Nickname";
                            ChunkyInput {
                                width: 240px;
                                text <=> root.settings-nickname;
                                accepted(t) => { root.nickname-changed(t); }
                            }
                        }
                        Labeled {
                            label: "Language";
                            Picker {
                                width: 240px;
                                model: root.languages;
                                placeholder: "—";
                                current <=> root.settings-language;
                                selected(i) => { root.language-selected(i); }
                            }
                        }
                        Labeled {
                            label: "Theme";
                            Picker {
                                width: 240px;
                                model: ["Dark", "Light"];
                                placeholder: "—";
                                current <=> root.settings-theme;
                                selected(i) => { root.theme-selected(i); }
                            }
                        }
                        Labeled {
                            label: "Data folder (Enter to apply + rescan)";
                            ChunkyInput {
                                width: 480px;
                                text <=> root.settings-data-path;
                                accepted(t) => { root.data-path-changed(t); }
                            }
                        }
                    }
                    if root.settings-section == 1 : VerticalLayout {
                        padding: 12px;
                        spacing: 14px;
                        alignment: start;
                        ChunkyCheckbox {
                            label: "Fractional scaling";
                            checked <=> root.fractional;
                            toggled(b) => { root.fractional-changed(b); }
                        }
                    }
                    if root.settings-section == 2 : VerticalLayout {
                        padding: 12px;
                        spacing: 14px;
                        alignment: start;
                        Labeled {
                            label: "Volume";
                            HorizontalLayout {
                                spacing: 8px;
                                ChunkySlider {
                                    value <=> root.settings-volume;
                                    changed(v) => { root.volume-changed(v); }
                                }
                                Text {
                                    text: root.settings-volume-label;
                                    font-size: 13px;
                                    color: Theme.text;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                    if root.settings-section == 5 : VerticalLayout {
                        padding: 12px;
                        spacing: 8px;
                        alignment: start;
                        Text {
                            text: "Tango NG";
                            font-size: 18px;
                            color: Theme.text;
                        }
                        Text {
                            text: root.app-version;
                            font-size: 11px;
                            color: Theme.text-muted;
                        }
                    }
                    if root.settings-section == 3 || root.settings-section == 4 : Text {
                        width: 100%;
                        height: 100%;
                        text: "Coming soon";
                        font-size: 13px;
                        color: Theme.text-muted;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }

    // ---- session view: replaces the whole body, no top bar ----
    if root.in-session : Rectangle {
        width: 100%;
        height: 100%;
        background: black;

        fs := FocusScope {
            width: 100%;
            height: 100%;
            init => { self.focus(); }
            key-pressed(event) => {
                root.key-event(event.text, true);
                accept
            }
            key-released(event) => {
                root.key-event(event.text, false);
                accept
            }

            // Integer scaling with a drop shadow, like the wgpu
            // framebuffer view; fractional scaling = smooth aspect-fit,
            // no shadow, matching tango's config.fractional_scaling.
            property <int> scale: max(1, Math.floor(min(
                self.width / 240px,
                self.height / 160px)));
            property <float> fscale: min(
                self.width / 240px,
                self.height / 160px);
            Rectangle {
                width: root.fractional ? 240px * fs.fscale : 240px * fs.scale;
                height: root.fractional ? 160px * fs.fscale : 160px * fs.scale;
                drop-shadow-blur: root.fractional ? 0px : 24px;
                drop-shadow-color: root.fractional ? transparent : #000000cc;
                Image {
                    width: 100%;
                    height: 100%;
                    source: root.frame;
                    image-fit: fill;
                    image-rendering: pixelated;
                }
            }
        }

        // Replay transport (floating_controls stand-in): play/pause,
        // tick readout, scrubber with prefetch fill + round marks,
        // speed picker.
        if root.session-kind == 1 : TechPlate {
            r: 10px;
            x: (parent.width - self.width) / 2;
            y: parent.height - self.height - 12px;
            width: min(parent.width - 24px, 680px);
            height: 56px;
            background: #000000b3;
            border-width: 1px;
            border-color: #ffffff1a;

            HorizontalLayout {
                padding: 8px;
                spacing: 12px;

                // circular play/pause
                Rectangle {
                    width: 40px;
                    height: 40px;
                    border-radius: 20px;
                    background: pta.has-hover ? #4caf50 : #ffffff14;
                    pta := TouchArea {
                        clicked => { root.toggle-pause(); }
                    }
                    LIcon {
                        width: 100%;
                        height: 100%;
                        text: root.replay-paused ? Glyphs.play : Glyphs.pause;
                        font-size: 15px;
                        color: white;
                    }
                }

                // scrubber
                scrub := Rectangle {
                    height: 40px;
                    horizontal-stretch: 1;
                    property <bool> dragging: sta.pressed;
                    property <float> drag-frac: max(0.0, min(1.0, sta.mouse-x / self.width));
                    property <float> shown: self.dragging ? self.drag-frac : root.replay-scrub-pos;

                    Rectangle {
                        y: parent.height / 2 - 3px;
                        height: 6px;
                        width: 100%;
                        border-radius: 3px;
                        background: #ffffff14;
                    }
                    Rectangle {
                        y: parent.height / 2 - 3px;
                        height: 6px;
                        width: parent.width * min(1.0, root.replay-prefetch);
                        border-radius: 3px;
                        background: #4caf5040;
                    }
                    Rectangle {
                        y: parent.height / 2 - 3px;
                        height: 6px;
                        width: parent.width * scrub.shown;
                        border-radius: 3px;
                        background: #4caf50;
                    }
                    for mark in root.replay-marks : Rectangle {
                        x: scrub.width * mark - 1px;
                        y: scrub.height / 2 - 6px;
                        width: 2px;
                        height: 12px;
                        background: #ffffff66;
                    }
                    Rectangle {
                        x: scrub.width * scrub.shown - 7px;
                        y: parent.height / 2 - 7px;
                        width: 14px;
                        height: 14px;
                        border-radius: 7px;
                        background: white;
                        border-width: 1px;
                        border-color: #00000040;
                    }
                    sta := TouchArea {
                        pointer-event(event) => {
                            if (event.kind == PointerEventKind.down) {
                                root.scrub-started();
                                root.scrub-moved(max(0.0, min(1.0, self.mouse-x / scrub.width)));
                            } else if (event.kind == PointerEventKind.up) {
                                root.scrub-committed(max(0.0, min(1.0, self.mouse-x / scrub.width)));
                            }
                        }
                        moved => {
                            if (self.pressed) {
                                root.scrub-moved(max(0.0, min(1.0, self.mouse-x / scrub.width)));
                            }
                        }
                    }
                }

                Text {
                    text: root.replay-progress;
                    font-size: 14px;
                    color: #4caf50;
                    vertical-alignment: center;
                }

                Picker {
                    width: 78px;
                    model: ["0.5×", "1×", "2×", "4×"];
                    placeholder: "1×";
                    current <=> root.replay-speed;
                    selected(i) => { root.speed-selected(i); }
                }
            }
        }

        // Quiet corner close chip (tear-down), top-right.
        TechPlate {
            r: 10px;
            x: parent.width - self.width - 12px;
            y: 12px;
            background: xta.has-hover ? #ff525233 : #00000080;
            border-width: 1px;
            border-color: xta.has-hover ? #ff5252aa : #ffffff1a;
            xta := TouchArea {
                clicked => { root.stop-clicked(); }
            }
            HorizontalLayout {
                padding-top: 6px;
                padding-bottom: 6px;
                padding-left: 8px;
                padding-right: 8px;
                LIcon {
                    text: Glyphs.x;
                    font-size: 13px;
                    color: xta.has-hover ? #ff5252 : Theme.text-muted;
                }
            }
        }
    }
}
